                }
            });
            isGroupDraggingRisers = false;
            groupRiserDragOffsets.clear();
        }
        
        woodwindRiserDragging = false;
        currentWoodwindRiser = null;
        woodwindRiserDragOffset = { x: 0, y: 0 };
    }

    // Prevent focus and blur any focused element to avoid blue box
    e.preventDefault();
    if (document.activeElement) {
        document.activeElement.blur();
    }

    // Remove global event listeners
    document.removeEventListener('mousemove', handleWoodwindRiserDragMove);
    document.removeEventListener('mouseup', handleWoodwindRiserDragEnd);
