function calculateSpace() {
    let usedSpace = 0;
    
    // Calculate used space for each instrument
    getAllInstruments().forEach(instrument => {
        const countElement = document.getElementById(instrument);
        const sqftElement = document.getElementById(instrument + '_sqft');
        if (countElement && sqftElement) {
            const count = parseInt(countElement.value) || 0;
            const sqft = parseFloat(sqftElement.value) || 0;
            usedSpace += count * sqft;
        }
    });

    const remainingSpace = TOTAL_STAGE_SPACE - usedSpace;
    
    // Space display removed - no longer needed
    // const spaceDisplay = document.getElementById('spaceDisplay');
    // const remainingSpaceElement = document.getElementById('remainingSpace');
    // remainingSpaceElement.textContent = remainingSpace.toFixed(2);
    // spaceDisplay.className = 'space-display';
    // if (remainingSpace < 0) {
    //     spaceDisplay.classList.add('danger');
    // } else if (remainingSpace < 100) {
    //     spaceDisplay.classList.add('warning');
    // }
    
    // Update stage plot
    updateStagePlot();
}

function resetCalculator() {
    const defaultValues = { 
        violin1: 10, violin2: 10, viola: 10, cello: 16, bass: 18,
        flute: 8, oboe: 8, clarinet: 8, bassoon: 12
    };

    // Reset static instruments
    staticInstruments.forEach(instrument => {
        document.getElementById(instrument).value = 0;
        document.getElementById(instrument + '_sqft').value = defaultValues[instrument];
        updateSqFtDisplay(instrument);
    });
    
    // Remove all dynamic instruments
    dynamicInstruments = [];
    document.getElementById('woodwindsInstruments').innerHTML = '';
    document.getElementById('percussionInstruments').innerHTML = '';
    document.getElementById('keyboardInstruments').innerHTML = '';
    updateEmptyDisplays();
    
    // Reset timpani riser checkbox
    document.getElementById('timpani-riser-checkbox').checked = true;
    toggleTimpaniRiser();
    
    // Reset brass risers checkboxes
    const brassRiserIds = ['brass-riser-1', 'brass-riser-2', 'brass-riser-3', 'brass-riser-4', 'brass-riser-5'];
    brassRiserIds.forEach(riserId => {
        document.getElementById(riserId + '-checkbox').checked = true;
        toggleBrassRiser(riserId);
    });
    
    // Reset woodwind risers checkboxes
    const woodwindRiserIds = ['woodwind-riser-1', 'woodwind-riser-2', 'woodwind-riser-3', 'woodwind-riser-4'];
    woodwindRiserIds.forEach(riserId => {
        document.getElementById(riserId + '-checkbox').checked = true;
        toggleWoodwindRiser(riserId);
    });
    
    calculateSpace();
}

function toggleDropdown(section) {
    const dropdown = document.getElementById('instrumentDropdown' + section.charAt(0).toUpperCase() + section.slice(1));
    dropdown.classList.toggle('show');
}

function addInstrument(instrumentId, instrumentName, defaultSqft) {
    // Check if instrument already exists
    if (dynamicInstruments.includes(instrumentId)) {
        alert(`${instrumentName} is already added to the stage.`);
        return;
    }

    const containerId = getContainerForInstrument(instrumentId);
    const container = document.getElementById(containerId);
    
    const instrumentDiv = document.createElement('div');
    instrumentDiv.className = 'input-group';
    instrumentDiv.innerHTML = `
        <label>${instrumentName}:</label>
        <input type="number" id="${instrumentId}" min="0" max="20" value="0">
        <div>
            <span class="sq-ft-display" data-instrument="${instrumentId}">${defaultSqft} sq ft each</span>
            <input type="number" id="${instrumentId}_sqft" class="sq-ft-input" min="1" max="100" value="${defaultSqft}" step="0.5">
        </div>
        <button class="remove-instrument-btn" onclick="removeInstrument('${instrumentId}')"></button>
    `;
    
    container.appendChild(instrumentDiv);
    dynamicInstruments.push(instrumentId);
    
    // Add event listeners
    addInstrumentEventListeners(instrumentId);
    
    // Hide empty message
    updateEmptyDisplays();
    
    // Close dropdown
    document.querySelectorAll('.dropdown-content').forEach(dropdown => {
        dropdown.classList.remove('show');
    });
    
    calculateSpace();
}

function addCustomInstrument() {
    const instrumentName = prompt('Enter instrument name:');
    if (!instrumentName) return;
    
    const defaultSqft = prompt('Enter space requirement (sq ft):', '10');
    if (!defaultSqft) return;
    
    const instrumentId = 'custom' + nextInstrumentId++;
    addInstrument(instrumentId, instrumentName, parseFloat(defaultSqft));
}

function removeInstrument(instrumentId) {
    const instrumentElement = document.getElementById(instrumentId);
    if (instrumentElement) {
        instrumentElement.parentElement.remove();
        dynamicInstruments = dynamicInstruments.filter(id => id !== instrumentId);
        updateEmptyDisplays();
        calculateSpace();
    }
}

function getContainerForInstrument(instrumentId) {
    const woodwinds = ['flute', 'oboe', 'clarinet', 'bassoon', 'saxophone', 'frenchhorn', 'trumpet', 'cornet', 'trombone', 'tuba'];
    const percussion = ['timpani', 'snare', 'xylophone', 'marimba', 'cymbals', 'vibraphone', 'glockenspiel', 'chimes', 'bassDrum', 'cymbal'];
    const keyboard = ['piano', 'celeste', 'harpsichord', 'keyboard', 'harp'];
    
    if (woodwinds.includes(instrumentId)) return 'woodwindsInstruments';
    if (percussion.includes(instrumentId)) return 'percussionInstruments';
    if (keyboard.includes(instrumentId)) return 'keyboardInstruments';
    
    // Default to woodwinds for custom instruments
    return 'woodwindsInstruments';
}

function updateEmptyDisplays() {
    const containers = [
        { id: 'woodwindsInstruments', emptyId: 'emptyWoodwinds' },
        { id: 'percussionInstruments', emptyId: 'emptyPercussion' },
        { id: 'keyboardInstruments', emptyId: 'emptyKeyboard' }
    ];
    
    containers.forEach(container => {
        const instrumentContainer = document.getElementById(container.id);
        const emptyMessage = document.getElementById(container.emptyId);
        
        if (instrumentContainer.children.length === 0) {
            emptyMessage.style.display = 'block';
        } else {
            emptyMessage.style.display = 'none';
        }
    });
}

function addInstrumentEventListeners(instrumentId) {
    document.getElementById(instrumentId).addEventListener('input', calculateSpace);
    
    const sqftInput = document.getElementById(instrumentId + '_sqft');
    sqftInput.addEventListener('input', calculateSpace);
    sqftInput.addEventListener('blur', () => stopEditing(instrumentId));
    sqftInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            sqftInput.blur();
        }
    });
    
    const sqftDisplay = document.querySelector(`.sq-ft-display[data-instrument="${instrumentId}"]`);
    sqftDisplay.addEventListener('click', () => startEditing(instrumentId));
}

function printToPDF() {
    // Generate timestamp
    const now = new Date();
    const timestamp = now.toLocaleDateString() + ' ' + now.toLocaleTimeString();
    
    // Update print elements
    document.querySelector('.print-date').textContent = `Generated: ${timestamp}`;
    
    // Generate summary
    let summary = '';
    let totalUsed = 0;
    
    getAllInstruments().forEach(instrument => {
        const countElement = document.getElementById(instrument);
        const sqftElement = document.getElementById(instrument + '_sqft');
        
        if (countElement && sqftElement) {
            const count = parseInt(countElement.value) || 0;
            const sqft = parseFloat(sqftElement.value) || 0;
            const total = count * sqft;
            
            if (count > 0) {
                const instrumentName = countElement.previousElementSibling.textContent.replace(':', '');
                totalUsed += total;
                summary += `<div>${instrumentName}: ${count} × ${sqft} sq ft = ${total} sq ft</div>`;
            }
        }
    });
    
    const remainingSpace = TOTAL_STAGE_SPACE - totalUsed;
    summary += `<div><strong>Total Used: ${totalUsed.toFixed(2)} sq ft</strong></div>`;
    summary += `<div><strong>Remaining: ${remainingSpace.toFixed(2)} sq ft</strong></div>`;
    summary += `<div><strong>Total Available: ${TOTAL_STAGE_SPACE.toFixed(2)} sq ft</strong></div>`;
    
    document.getElementById('printSummaryContent').innerHTML = summary;
    
    // Print
    window.print();
}

function printStagePlot() {
    // Add print-plot-only class to body
    document.body.classList.add('print-plot-only');
    
    // Print the page
    window.print();
    
    // Remove the class after printing (with a slight delay to ensure print dialog has opened)
    setTimeout(() => {
        document.body.classList.remove('print-plot-only');
    }, 100);
}

function toggleDebugMode() {
    debugMode = !debugMode;
    const debugBtn = document.querySelector('.debug-btn');
    const debugInfo = document.querySelector('.debug-info');
    const highlights = document.querySelectorAll('.position-highlight');
    
    if (debugMode) {
        debugBtn.textContent = 'Debug Mode: ON';
        debugInfo.classList.add('show');
        highlights.forEach(h => h.classList.add('show'));
        updateDebugInfo();
    } else {
        debugBtn.textContent = 'Debug Mode: OFF';
        debugInfo.classList.remove('show');
        highlights.forEach(h => h.classList.remove('show'));
    }
}

function toggleCollisionDetection() {
    const checkbox = document.getElementById('collision-detection-toggle');
    collisionDetectionEnabled = checkbox.checked;
    console.log('Collision detection:', collisionDetectionEnabled ? 'ON' : 'OFF');
}

function updateDebugInfo() {
    if (!debugMode) return;
    
    const debugDiv = document.querySelector('.debug-info div');
    let debugText = '';
    
    // Player Positions
    debugText += 'Player Positions:\n';
    const players = document.querySelectorAll('.stage-plot circle[data-player-id], .stage-plot ellipse[data-player-id]');
    players.forEach(player => {
        const playerId = player.getAttribute('data-player-id');
        const cx = parseFloat(player.getAttribute('cx'));
        const cy = parseFloat(player.getAttribute('cy'));
        debugText += `${playerId}: (${cx.toFixed(1)}, ${cy.toFixed(1)})\n`;
    });
    
    // Podium Position
    debugText += '\nPodium Position:\n';
    debugText += `podium: (${podiumPosition.x.toFixed(1)}, ${podiumPosition.y.toFixed(1)})\n`;
    
    // Concert Grand Position
    if (concertGrandEnabled) {
        debugText += '\nConcert Grand Position:\n';
        debugText += `concert-grand: (${concertGrandPosition.x.toFixed(1)}, ${concertGrandPosition.y.toFixed(1)})\n`;
    }
    
    // Timpani Riser Position
    debugText += '\nTimpani Riser Position:\n';
    debugText += `timpani-riser: (${timpaniRiserPosition.x.toFixed(1)}, ${timpaniRiserPosition.y.toFixed(1)})\n`;
    
    // Brass Riser Positions
    debugText += '\nBrass Riser Positions:\n';
    Object.keys(brassRiserPositions).forEach(riserId => {
        const pos = brassRiserPositions[riserId];
        debugText += `${riserId}: (${pos.x.toFixed(1)}, ${pos.y.toFixed(1)})\n`;
    });
    
    // Woodwind Riser Positions
    debugText += '\nWoodwind Riser Positions:\n';
    Object.keys(woodwindRiserPositions).forEach(riserId => {
        const pos = woodwindRiserPositions[riserId];
        debugText += `${riserId}: (${pos.x.toFixed(1)}, ${pos.y.toFixed(1)})\n`;
    });
    
    // Extra Riser Positions
    debugText += '\nExtra Riser Positions:\n';
    extraRisers.forEach(riserData => {
        debugText += `${riserData.id}: (${riserData.x.toFixed(1)}, ${riserData.y.toFixed(1)})\n`;
    });
    
    // Chorus Riser Positions
    if (chorusEnabled && chorusRisers.length > 0) {
        debugText += '\nChorus Riser Positions:\n';
        chorusRisers.forEach(riserData => {
            debugText += `${riserData.id}: (${riserData.x.toFixed(1)}, ${riserData.y.toFixed(1)})\n`;
        });
    }
    
    // Chorus Singer Positions
    if (chorusEnabled && chorusSingers.length > 0) {
        debugText += '\nChorus Singer Positions:\n';
        chorusSingers.forEach(singerData => {
            debugText += `${singerData.id}: (${singerData.x.toFixed(1)}, ${singerData.y.toFixed(1)})\n`;
        });
        debugText += `Total Singers: ${chorusSingers.length}\n`;
    }
    
    // Percussion Blob Info
    debugText += '\nPercussion Blob:\n';
    if (percussionBlob.controlPoints.length > 0) {
        debugText += `  Target Area: ${percussionBlob.targetArea.toFixed(1)} sq ft\n`;
        debugText += `  Actual Area: ${percussionBlob.actualArea.toFixed(1)} sq ft\n`;
        debugText += `  Center: (${percussionBlob.center.x.toFixed(1)}, ${percussionBlob.center.y.toFixed(1)})\n`;
        debugText += `  Control Points: ${percussionBlob.controlPoints.length}\n`;
    } else {
        debugText += '  No percussion instruments added\n';
    }
    
    debugDiv.textContent = debugText;
}

function exportPositions() {
    const positions = {};
    const players = document.querySelectorAll('.stage-plot circle[data-player-id], .stage-plot ellipse[data-player-id]');
    
    players.forEach(player => {
        const playerId = player.getAttribute('data-player-id');
        const cx = parseFloat(player.getAttribute('cx'));
        const cy = parseFloat(player.getAttribute('cy'));
        positions[playerId] = { x: cx, y: cy };
    });
    
    // Create exportable JavaScript code
    const exportCode = `// Generated Position Data
const generatedPositions = ${JSON.stringify(positions, null, 2)};

// Example usage in your position arrays:
// Replace your hardcoded positions with:
// const positions = generatedPositions;`;
    
    // Copy to clipboard and show alert
    navigator.clipboard.writeText(exportCode).then(() => {
        alert('Position data copied to clipboard!\n\nYou can paste this into your code to use the current positions as the new default positions.');
    }).catch(() => {
        // Fallback for browsers that don't support clipboard API
        const textarea = document.createElement('textarea');
        textarea.value = exportCode;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        alert('Position data copied to clipboard!');
    });
    
    console.log('Exported positions:', positions);
}

// Multi-select functionality
function initializeMultiSelect() {
    const svg = document.querySelector('.stage-plot');
    if (!svg) return;
    
    // Add event listeners for selection rectangle
    svg.addEventListener('mousedown', handleSelectionStart);
    svg.addEventListener('mousemove', handleSelectionMove);
    svg.addEventListener('mouseup', handleSelectionEnd);
    
    // Add keyboard listener for deselection
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            clearSelection();
        }
    });
}

function handleSelectionStart(e) {
    // Only start selection if clicking on empty stage area (not on a player or riser)
    if ((e.target.tagName === 'circle' || e.target.tagName === 'ellipse') && e.target.hasAttribute('data-player-id')) {
        return; // Let individual player drag handle this
    }
    
    // Don't start selection if clicking on a riser
    if (e.target.classList.contains('riser-draggable')) {
        return; // Let individual riser drag handle this
    }
    
    // Clear previous selection if not holding Ctrl/Cmd/Shift
    if (!e.ctrlKey && !e.metaKey && !e.shiftKey) {
        clearSelection();
    }
    
    isSelecting = true;
    
    // Get SVG coordinates
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    selectionStart.x = (e.clientX - rect.left) * scaleX;
    selectionStart.y = (e.clientY - rect.top) * scaleY;
    
    // Create selection rectangle
    selectionRect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    selectionRect.setAttribute('class', 'selection-rectangle');
    selectionRect.setAttribute('x', selectionStart.x);
    selectionRect.setAttribute('y', selectionStart.y);
    selectionRect.setAttribute('width', 0);
    selectionRect.setAttribute('height', 0);
    svg.appendChild(selectionRect);
    
    e.preventDefault();
}

function handleSelectionMove(e) {
    if (!isSelecting || !selectionRect) return;
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const currentX = (e.clientX - rect.left) * scaleX;
    const currentY = (e.clientY - rect.top) * scaleY;
    
    const x = Math.min(selectionStart.x, currentX);
    const y = Math.min(selectionStart.y, currentY);
    const width = Math.abs(currentX - selectionStart.x);
    const height = Math.abs(currentY - selectionStart.y);
    
    selectionRect.setAttribute('x', x);
    selectionRect.setAttribute('y', y);
    selectionRect.setAttribute('width', width);
    selectionRect.setAttribute('height', height);
    
    // Update selection based on rectangle
    updateSelectionFromRectangle(x, y, width, height);
}

function handleSelectionEnd(e) {
    if (!isSelecting) return;
    
    isSelecting = false;
    
    // Remove selection rectangle
    if (selectionRect) {
        selectionRect.remove();
        selectionRect = null;
    }
}

function updateSelectionFromRectangle(x, y, width, height) {
    // Select players (both circles and ellipses)
    const players = document.querySelectorAll('.stage-plot circle[data-player-id], .stage-plot ellipse[data-player-id]');
    
    players.forEach(player => {
        const cx = parseFloat(player.getAttribute('cx'));
        const cy = parseFloat(player.getAttribute('cy'));
        
        // Get effective radius (for ellipses, use rx and ry)
        let rx, ry;
        if (player.tagName === 'ellipse') {
            rx = parseFloat(player.getAttribute('rx'));
            ry = parseFloat(player.getAttribute('ry'));
        } else {
            const r = parseFloat(player.getAttribute('r'));
            rx = r;
            ry = r;
        }
        
        // Check if player intersects with selection rectangle
        const isInside = (cx + rx >= x && cx - rx <= x + width && 
                        cy + ry >= y && cy - ry <= y + height);
        
        const playerId = player.getAttribute('data-player-id');
        
        if (isInside) {
            addToSelection(playerId, player);
        } else {
            removeFromSelection(playerId, player);
        }
    });
    
    // Select chorus singers
    const singers = document.querySelectorAll('.stage-plot rect[data-singer-id]');
    
    singers.forEach(singer => {
        const singerData = chorusSingers.find(s => s.id === singer.getAttribute('data-singer-id'));
        if (!singerData) return;
        
        const singerX = singerData.x;
        const singerY = singerData.y;
        const halfSize = singerData.size / 2;
        
        // Check if singer intersects with selection rectangle
        const isInside = (singerX + halfSize >= x && singerX - halfSize <= x + width && 
                        singerY + halfSize >= y && singerY - halfSize <= y + height);
        
        const singerId = singer.getAttribute('data-singer-id');
        
        if (isInside) {
            addToSelection(singerId, singer);
        } else {
            removeFromSelection(singerId, singer);
        }
    });

    // Select risers
    const risers = document.querySelectorAll('.stage-plot .riser-draggable');
    
    risers.forEach(riser => {
        const riserId = riser.getAttribute('id');
        if (!riserId) return;
        
        let riserX, riserY, riserWidth, riserHeight;
        
        // Get riser bounds based on type
        if (riserId.startsWith('brass-riser-') || riserId.startsWith('woodwind-riser-')) {
            // Rectangle risers
            riserX = parseFloat(riser.getAttribute('x'));
            riserY = parseFloat(riser.getAttribute('y'));
            riserWidth = parseFloat(riser.getAttribute('width'));
            riserHeight = parseFloat(riser.getAttribute('height'));
        } else if (riserId === 'timpani-riser') {
            // Rectangle riser
            riserX = parseFloat(riser.getAttribute('x'));
            riserY = parseFloat(riser.getAttribute('y'));
            riserWidth = parseFloat(riser.getAttribute('width'));
            riserHeight = parseFloat(riser.getAttribute('height'));
        } else if (riserId.startsWith('extra-riser-') || riserId.startsWith('chorus-riser-')) {
            // Extra risers and chorus risers (user-created/movable)
            riserX = parseFloat(riser.getAttribute('x'));
            riserY = parseFloat(riser.getAttribute('y'));
            riserWidth = parseFloat(riser.getAttribute('width'));
            riserHeight = parseFloat(riser.getAttribute('height'));
        } else {
            // Skip non-riser elements
            return;
        }
        
        // Check if riser rectangle intersects with selection rectangle
        const isInside = (riserX < x + width && riserX + riserWidth > x && 
                        riserY < y + height && riserY + riserHeight > y);
        
        if (isInside) {
            addRiserToSelection(riserId, riser);
        } else {
            removeRiserFromSelection(riserId, riser);
        }
    });
}

function addToSelection(playerId, playerElement) {
    selectedPlayers.add(playerId);
    playerElement.classList.add('player-selected');
}

function removeFromSelection(playerId, playerElement) {
    selectedPlayers.delete(playerId);
    playerElement.classList.remove('player-selected');
}

function addRiserToSelection(riserId, riserElement) {
    selectedRisers.add(riserId);
    riserElement.classList.add('selected');
}

function removeRiserFromSelection(riserId, riserElement) {
    selectedRisers.delete(riserId);
    riserElement.classList.remove('selected');
}

function clearSelection() {
    // Clear player and singer selections
    selectedPlayers.forEach(id => {
        const element = document.querySelector(`[data-player-id="${id}"], [data-singer-id="${id}"]`);
        if (element) {
            element.classList.remove('player-selected');
        }
    });
    selectedPlayers.clear();
    
    // Clear riser selections
    selectedRisers.forEach(riserId => {
        const riser = document.getElementById(riserId);
        if (riser) {
            riser.classList.remove('selected');
        }
    });
    selectedRisers.clear();
}

function togglePlayerSelection(playerId, playerElement) {
    if (selectedPlayers.has(playerId)) {
        removeFromSelection(playerId, playerElement);
    } else {
        addToSelection(playerId, playerElement);
    }
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(event) {
    if (!event.target.matches('.add-instrument-btn')) {
        document.querySelectorAll('.dropdown-content').forEach(dropdown => {
            dropdown.classList.remove('show');
        });
    }
});

function deleteSelectedRisers() {
    let risersToDelete = [];
    
    // Collect risers to delete from multiple selection
    if (selectedRisers.size > 0) {
        risersToDelete = Array.from(selectedRisers);
    } 
    // Or from single selection
    else if (selectedObject && (selectedObjectType === 'timpani-riser' || 
             selectedObjectType === 'brass-riser' || selectedObjectType === 'woodwind-riser' ||
             selectedObject.startsWith('extra-riser-') || selectedObject.startsWith('chorus-riser-'))) {
        risersToDelete = [selectedObject];
    }
    
    if (risersToDelete.length === 0) return;
    
    // Process each riser for deletion
    risersToDelete.forEach(riserId => {
        if (riserId === 'timpani-riser') {
            // Uncheck timpani riser checkbox
            const checkbox = document.getElementById('timpani-riser-checkbox');
            if (checkbox) {
                checkbox.checked = false;
                toggleTimpaniRiser();
            }
        } else if (riserId.startsWith('brass-riser-')) {
            // Uncheck brass riser checkbox
            const checkbox = document.getElementById(riserId + '-checkbox');
            if (checkbox) {
                checkbox.checked = false;
                toggleBrassRiser(riserId);
            }
        } else if (riserId.startsWith('woodwind-riser-')) {
            // Uncheck woodwind riser checkbox
            const checkbox = document.getElementById(riserId + '-checkbox');
            if (checkbox) {
                checkbox.checked = false;
                toggleWoodwindRiser(riserId);
            }
        } else if (riserId.startsWith('extra-riser-')) {
            // Remove extra riser
            const riserIndex = extraRisers.findIndex(r => r.id === riserId);
            if (riserIndex !== -1) {
                // Remove from array
                extraRisers.splice(riserIndex, 1);
                
                // Remove SVG elements
                const riserElement = document.getElementById(riserId);
                const labelElement = document.getElementById(riserId + '-label');
                
                if (riserElement) riserElement.remove();
                if (labelElement) labelElement.remove();
                
                // Update counter
                updateExtraRiserCount();
            }
        } else if (riserId.startsWith('chorus-riser-')) {
            // Remove chorus riser
            const riserIndex = chorusRisers.findIndex(r => r.id === riserId);
            if (riserIndex !== -1) {
                const riserData = chorusRisers[riserIndex];
                
                // Remove from array
                chorusRisers.splice(riserIndex, 1);
                
                // Remove SVG elements
                const riserElement = document.getElementById(riserId);
                const labelElement = document.getElementById(riserId + '-label');
                
                if (riserElement) riserElement.remove();
                if (labelElement) labelElement.remove();
                
                // Get the row index for this riser
                const riserNumber = parseInt(riserId.match(/chorus-riser-(\d+)/)?.[1] || '0');
                const rowIndex = Math.floor((riserNumber - 1) / 4);
                
                // Regenerate singers for this row to adjust spacing
                const singersInRow = chorusSingersPerRow[rowIndex] || 0;
                if (singersInRow > 0) {
                    clearChorusSingersForRow(rowIndex);
                    createSingersForRow(rowIndex, singersInRow);
                }
            }
        }
        
        // Remove from selection
        selectedRisers.delete(riserId);
        const riserElement = document.getElementById(riserId);
        if (riserElement) {
            riserElement.classList.remove('selected');
        }
    });
    
    // Clear single selection if it was an extra riser
    if (selectedObject && selectedObject.startsWith('extra-riser-')) {
        selectedObject = null;
        selectedObjectType = null;
    }
    
    // Update stage plot
    updateStagePlot();
}

// Keyboard navigation for fine-tuning positions and deletion
document.addEventListener('keydown', function(event) {
    // Handle Delete key for risers
    if (event.key === 'Delete' || event.key === 'Backspace') {
        if (selectedRisers.size > 0) {
            event.preventDefault();
            deleteSelectedRisers();
            return;
        } else if (selectedObject && (selectedObjectType === 'timpani-riser' || 
                   selectedObjectType === 'brass-riser' || selectedObjectType === 'woodwind-riser' ||
                   selectedObject.startsWith('extra-riser-'))) {
            event.preventDefault();
            deleteSelectedRisers();
            return;
        }
    }
    
    // Handle arrow keys for movement (both single and group selections)
    if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(event.key)) {
        event.preventDefault();
        
        let deltaX = 0;
        let deltaY = 0;
        
        switch(event.key) {
            case 'ArrowUp':
                deltaY = -1;
                break;
            case 'ArrowDown':
                deltaY = 1;
                break;
            case 'ArrowLeft':
                deltaX = -1;
                break;
            case 'ArrowRight':
                deltaX = 1;
                break;
        }
        
        // If Shift is held, move 10x faster
        if (event.shiftKey) {
            deltaX *= 10;
            deltaY *= 10;
        }
        
        // Check if we have group selections first
        if (selectedPlayers.size > 0) {
            moveSelectedPlayers(deltaX, deltaY);
        } else if (selectedRisers.size > 0) {
            moveSelectedRisers(deltaX, deltaY);
        } else if (selectedObject) {
            moveSelectedObject(deltaX, deltaY);
        }
    }
});

function moveSelectedPlayers(deltaX, deltaY) {
    // Move all selected players and singers together as a group
    selectedPlayers.forEach(id => {
        // Check if it's a singer or a player
        if (id.startsWith('singer-')) {
            moveSinger(id, deltaX, deltaY);
        } else {
            movePlayer(id, deltaX, deltaY);
        }
    });
}

function moveSinger(singerId, deltaX, deltaY) {
    const singerData = chorusSingers.find(s => s.id === singerId);
    if (!singerData) return;
    
    let newX = singerData.x + deltaX;
    let newY = singerData.y + deltaY;
    
    // Constrain to canvas boundaries
    newX = Math.max(0, Math.min(1000, newX));
    newY = Math.max(0, Math.min(940, newY));
    
    // Update singer data
    singerData.x = newX;
    singerData.y = newY;
    
    // Update visual element
    const singerElement = document.getElementById(singerId);
    if (singerElement) {
        singerElement.setAttribute('x', newX - singerData.size / 2);
        singerElement.setAttribute('y', newY - singerData.size / 2);
    }
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function moveSelectedRisers(deltaX, deltaY) {
    // Move all selected risers together as a group
    selectedRisers.forEach(riserId => {
        if (riserId === 'timpani-riser') {
            moveTimpaniRiser(deltaX, deltaY);
        } else if (riserId.startsWith('brass-riser-')) {
            moveBrassRiser(riserId, deltaX, deltaY);
        } else if (riserId.startsWith('woodwind-riser-')) {
            moveWoodwindRiser(riserId, deltaX, deltaY);
        } else if (riserId.startsWith('extra-riser-')) {
            moveExtraRiser(riserId, deltaX, deltaY);
        } else if (riserId.startsWith('chorus-riser-')) {
            moveChorusRiser(riserId, deltaX, deltaY);
        }
    });
}

function moveSelectedObject(deltaX, deltaY) {
    if (!selectedObject) return;
    
    switch(selectedObjectType) {
        case 'player':
            movePlayer(selectedObject, deltaX, deltaY);
            break;
        case 'singer':
            moveSinger(selectedObject, deltaX, deltaY);
            break;
        case 'podium':
            movePodium(deltaX, deltaY);
            break;
        case 'concert-grand':
            moveConcertGrand(deltaX, deltaY);
            break;
        case 'timpani-riser':
            moveTimpaniRiser(deltaX, deltaY);
            break;
        case 'brass-riser':
            moveBrassRiser(selectedObject, deltaX, deltaY);
            break;
        case 'woodwind-riser':
            moveWoodwindRiser(selectedObject, deltaX, deltaY);
            break;
        default:
            // Handle extra risers and chorus risers (selectedObjectType is the riserId itself)
            if (selectedObject && selectedObject.startsWith('extra-riser-')) {
                moveExtraRiser(selectedObject, deltaX, deltaY);
            } else if (selectedObject && selectedObject.startsWith('chorus-riser-')) {
                moveChorusRiser(selectedObject, deltaX, deltaY);
            }
            break;
    }
}

function movePlayer(playerId, deltaX, deltaY) {
    const player = document.querySelector(`[data-player-id="${playerId}"]`);
    if (!player) return;
    
    const currentX = parseFloat(player.getAttribute('cx'));
    const currentY = parseFloat(player.getAttribute('cy'));
    
    let newX = currentX + deltaX;
    let newY = currentY + deltaY;
    
    // Check collision detection if enabled
    let finalPos;
    if (collisionDetectionEnabled) {
        finalPos = findClosestValidPosition(playerId, currentX, currentY, newX, newY, new Set());
    } else {
        finalPos = { x: newX, y: newY };
    }
    
    // Constrain to stage boundaries
    if (isInsideStage(finalPos.x, finalPos.y, 15)) {
        player.setAttribute('cx', finalPos.x);
        player.setAttribute('cy', finalPos.y);
        
        // Update orientation toward podium (for ellipses)
        updatePlayerOrientation(player, finalPos.x, finalPos.y);
        
        // Update label position
        const label = player.nextElementSibling;
        if (label && label.tagName === 'text') {
            label.setAttribute('x', finalPos.x);
            label.setAttribute('y', finalPos.y);
        }
        
        // Store custom position
        customPositions[playerId] = { x: finalPos.x, y: finalPos.y };
        
        // Update debug info if in debug mode
        if (debugMode) {
            updateDebugInfo();
        }
    }
}

function movePodium(deltaX, deltaY) {
    let newX = podiumPosition.x + deltaX;
    let newY = podiumPosition.y + deltaY;
    
    // Constrain to stage boundaries (using smaller padding since podium is near bottom edge)
    if (isInsideStage(newX, newY, 10)) {
        podiumPosition = { x: newX, y: newY };
        updatePodiumPosition();
        
        // Update all player orientations to face the new podium position
        updateAllPlayerOrientations();
        
        // Update debug info if in debug mode
        if (debugMode) {
            updateDebugInfo();
        }
    }
}

function moveTimpaniRiser(deltaX, deltaY) {
    let newX = timpaniRiserPosition.x + deltaX;
    let newY = timpaniRiserPosition.y + deltaY;
    
    // Constrain to stage boundaries
    const stageBounds = {
        left: 185 + 10,
        right: 815 - 130,
        top: 80 + 10,
        bottom: 665 - 130
    };
    
    newX = Math.max(stageBounds.left, Math.min(stageBounds.right, newX));
    newY = Math.max(stageBounds.top, Math.min(stageBounds.bottom, newY));
    
    timpaniRiserPosition = { x: newX, y: newY };
    updateTimpaniRiserPosition();
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function moveBrassRiser(riserId, deltaX, deltaY) {
    let newX = brassRiserPositions[riserId].x + deltaX;
    let newY = brassRiserPositions[riserId].y + deltaY;
    
    // Constrain to stage boundaries
    const stageBounds = {
        left: 185 + 10,
        right: 815 - 130,
        top: 80 + 10,
        bottom: 665 - 70
    };
    
    newX = Math.max(stageBounds.left, Math.min(stageBounds.right, newX));
    newY = Math.max(stageBounds.top, Math.min(stageBounds.bottom, newY));
    
    brassRiserPositions[riserId] = { x: newX, y: newY };
    updateBrassRiserPosition(riserId);
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function moveWoodwindRiser(riserId, deltaX, deltaY) {
    let newX = woodwindRiserPositions[riserId].x + deltaX;
    let newY = woodwindRiserPositions[riserId].y + deltaY;
    
    // Constrain to stage boundaries
    const stageBounds = {
        left: 185 + 10,
        right: 815 - 130,
        top: 80 + 10,
        bottom: 665 - 70
    };
    
    newX = Math.max(stageBounds.left, Math.min(stageBounds.right, newX));
    newY = Math.max(stageBounds.top, Math.min(stageBounds.bottom, newY));
    
    woodwindRiserPositions[riserId] = { x: newX, y: newY };
    updateWoodwindRiserPosition(riserId);
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function moveExtraRiser(riserId, deltaX, deltaY) {
    const riserData = extraRisers.find(r => r.id === riserId);
    if (!riserData) return;
    
    let newX = riserData.x + deltaX;
    let newY = riserData.y + deltaY;
    
    // Constrain to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000 - riserData.config.width,
        top: 0,
        bottom: 940 - riserData.config.height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Don't use snap-to for keyboard movement (too aggressive for 1px movements)
    // Just update to the new position directly
    riserData.x = newX;
    riserData.y = newY;
    updateExtraRiserPosition(riserData);
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function selectObject(objectId, objectType) {
    // Clear previous selection
    clearKeyboardSelection();
    
    selectedObject = objectId;
    selectedObjectType = objectType;
    
    // Add visual selection indicator
    const element = document.getElementById(objectId);
    if (element) {
        if (objectType === 'player') {
            element.classList.add('keyboard-selected-player');
        } else {
            element.classList.add('keyboard-selected');
        }
    }
    
    // Show keyboard navigation info
    const info = document.getElementById('keyboard-nav-info');
    const nameSpan = document.getElementById('selected-object-name');
    if (info && nameSpan) {
        let displayName = objectId;
        if (objectType === 'player') {
            displayName = `Player ${objectId}`;
        } else if (objectType === 'podium') {
            displayName = 'Podium';
        } else if (objectType === 'concert-grand') {
            displayName = 'Concert Grand';
        } else if (objectType === 'timpani-riser') {
            displayName = 'Timpani Riser';
        } else if (objectType === 'brass-riser') {
            displayName = objectId.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase());
        } else if (objectType === 'woodwind-riser') {
            displayName = objectId.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase());
        } else if (objectId.startsWith('chorus-riser-')) {
            displayName = objectId.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase());
        }
        nameSpan.textContent = displayName;
        info.style.display = 'block';
    }
}

function clearKeyboardSelection() {
    if (selectedObject) {
        const element = document.getElementById(selectedObject);
        if (element) {
            element.classList.remove('keyboard-selected', 'keyboard-selected-player');
        }
    }
    
    selectedObject = null;
    selectedObjectType = null;
    
    // Hide keyboard navigation info
    const info = document.getElementById('keyboard-nav-info');
    if (info) {
        info.style.display = 'none';
    }
}

// Save and Load Functionality
function saveState() {
    try {
    const state = {
        // Metadata
        version: "1.0",
        timestamp: new Date().toISOString(),
        
        // Static instruments
        staticInstruments: {},
        
        // Dynamic instruments
        dynamicInstruments: [...dynamicInstruments],
        dynamicInstrumentData: {},
        nextInstrumentId: nextInstrumentId,
        
        // Player positions
        customPositions: {...customPositions},
        useDefaultSeating: useDefaultSeating,
        
        // Riser positions
        podiumPosition: {...podiumPosition},
        podiumOriginalY: podiumOriginalY,
        concertGrandEnabled: concertGrandEnabled,
        concertGrandPosition: {...concertGrandPosition},
        timpaniRiserPosition: {...timpaniRiserPosition},
        brassRiserPositions: {...brassRiserPositions},
        woodwindRiserPositions: {...woodwindRiserPositions},
        
        // Chorus state
        chorusEnabled: chorusEnabled,
        chorusRows: chorusRows,
        chorusSingersPerRow: [...chorusSingersPerRow],
        chorusRisers: (chorusRisers || []).map(riser => ({
            id: riser.id,
            size: riser.size,
            x: riser.x,
            y: riser.y,
            number: riser.number
        })),
        chorusSingers: (chorusSingers || []).map(singer => ({
            id: singer.id,
            rowIndex: singer.rowIndex,
            x: singer.x,
            y: singer.y,
            size: singer.size
        })),
        
        // Extra risers (user-added risers)
        extraRisers: (extraRisers || []).map(riser => ({
            id: riser.id,
            size: riser.size,
            x: riser.x,
            y: riser.y,
            number: riser.number || parseInt(riser.id.match(/extra-riser-(\d+)/)?.[1] || '0', 10)
        })),
        
        // Percussion blob
        percussionBlob: {
            enabled: percussionBlob.enabled,
            targetArea: percussionBlob.targetArea,
            center: { ...percussionBlob.center },
            controlPoints: percussionBlob.controlPoints.map(p => ({ x: p.x, y: p.y }))
        },
        
        // Riser visibility
        riserVisibility: {
            timpaniRiser: document.getElementById('timpani-riser-checkbox').checked,
            brassRisers: {},
            woodwindRisers: {},
            stageExtensions: {}
        },
        
        // Debug mode
        debugMode: debugMode
    };
    
    // Capture static instrument data
    staticInstruments.forEach(instrument => {
        const countElement = document.getElementById(instrument);
        const sqftElement = document.getElementById(instrument + '_sqft');
        if (countElement && sqftElement) {
            state.staticInstruments[instrument] = {
                count: parseInt(countElement.value) || 0,
                sqft: parseFloat(sqftElement.value) || 0
            };
        }
    });
    
    // Capture dynamic instrument data
    dynamicInstruments.forEach(instrumentId => {
        const countElement = document.getElementById(instrumentId);
        const sqftElement = document.getElementById(instrumentId + '_sqft');
        if (countElement && sqftElement) {
            // Get instrument name from the label
            const label = countElement.parentElement.querySelector('label');
            const instrumentName = label ? label.textContent.replace(':', '') : instrumentId;
            
            state.dynamicInstrumentData[instrumentId] = {
                name: instrumentName,
                count: parseInt(countElement.value) || 0,
                sqft: parseFloat(sqftElement.value) || 0
            };
        }
    });
    
    // Capture brass riser visibility
    const brassRiserIds = ['brass-riser-1', 'brass-riser-2', 'brass-riser-3', 'brass-riser-4', 'brass-riser-5'];
    brassRiserIds.forEach(riserId => {
        const checkbox = document.getElementById(riserId + '-checkbox');
        if (checkbox) {
            state.riserVisibility.brassRisers[riserId] = checkbox.checked;
        }
    });
    
    // Capture woodwind riser visibility
    const woodwindRiserIds = ['woodwind-riser-1', 'woodwind-riser-2', 'woodwind-riser-3', 'woodwind-riser-4'];
    woodwindRiserIds.forEach(riserId => {
        const checkbox = document.getElementById(riserId + '-checkbox');
        if (checkbox) {
            state.riserVisibility.woodwindRisers[riserId] = checkbox.checked;
        }
    });
    
    // Capture stage extension visibility
    const stageExtensionIds = ['stage-extension-1', 'stage-extension-2'];
    stageExtensionIds.forEach(extensionId => {
        const checkbox = document.getElementById(extensionId + '-checkbox');
        if (checkbox) {
            state.riserVisibility.stageExtensions[extensionId] = checkbox.checked;
        }
    });
    
    // Create and download JSON file
    const jsonString = JSON.stringify(state, null, 2);
    const blob = new Blob([jsonString], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    
    // Create download link
    const link = document.createElement('a');
    link.href = url;
    link.download = `orchestra-stage-plot-${new Date().toISOString().slice(0, 19).replace(/:/g, '-')}.json`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    URL.revokeObjectURL(url);
    
    // Show success message
    alert('Stage plot configuration saved successfully!');
    } catch (error) {
        console.error('Error saving state:', error);
        alert('Error saving stage plot: ' + error.message);
    }
}

function loadState() {
    // Trigger file input
    document.getElementById('loadFileInput').click();
}

function handleFileLoad(event) {
    const file = event.target.files[0];
    if (!file) return;
    
    if (file.type !== 'application/json') {
        alert('Please select a valid JSON file.');
        return;
    }
    
    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const state = JSON.parse(e.target.result);
            restoreState(state);
        } catch (error) {
            alert('Error reading file: Invalid JSON format.');
            console.error('Error parsing JSON:', error);
        }
    };
    reader.readAsText(file);
    
    // Clear the file input so the same file can be loaded again
    event.target.value = '';
}

function restoreState(state) {
    try {
        // Clear current state first
        resetCalculator();
        
        // Restore static instruments
        if (state.staticInstruments) {
            Object.keys(state.staticInstruments).forEach(instrument => {
                const data = state.staticInstruments[instrument];
                const countElement = document.getElementById(instrument);
                const sqftElement = document.getElementById(instrument + '_sqft');
                
                if (countElement && sqftElement) {
                    countElement.value = data.count;
                    sqftElement.value = data.sqft;
                    updateSqFtDisplay(instrument);
                }
            });
        }
        
        // Restore dynamic instruments
        if (state.dynamicInstruments && state.dynamicInstrumentData) {
            // Clear existing dynamic instruments
            dynamicInstruments = [];
            document.getElementById('woodwindsInstruments').innerHTML = '';
            document.getElementById('percussionInstruments').innerHTML = '';
            document.getElementById('keyboardInstruments').innerHTML = '';
            
            // Restore nextInstrumentId
            if (state.nextInstrumentId) {
                nextInstrumentId = state.nextInstrumentId;
            }
            
            // Add each dynamic instrument
            state.dynamicInstruments.forEach(instrumentId => {
                const data = state.dynamicInstrumentData[instrumentId];
                if (data) {
                    addInstrument(instrumentId, data.name, data.sqft);
                    
                    // Set the count and sqft values
                    const countElement = document.getElementById(instrumentId);
                    const sqftElement = document.getElementById(instrumentId + '_sqft');
                    if (countElement && sqftElement) {
                        countElement.value = data.count;
                        sqftElement.value = data.sqft;
                        updateSqFtDisplay(instrumentId);
                    }
                }
            });
        }
        
        // Restore positions
        if (state.customPositions) {
            customPositions = {...state.customPositions};
        }
        
        // Always disable default seating when loading a saved plot
        // (Loaded plots should preserve custom positions, not regenerate from templates)
        useDefaultSeating = false;
        const checkbox = document.getElementById('use-default-seating');
        if (checkbox) {
            checkbox.checked = false;
        }
        
        if (state.podiumPosition) {
            podiumPosition = {...state.podiumPosition};
            updatePodiumPosition();
        }
        
        if (state.podiumOriginalY !== undefined) {
            podiumOriginalY = state.podiumOriginalY;
        }
        
        // Restore concert grand
        if (state.concertGrandEnabled !== undefined) {
            concertGrandEnabled = state.concertGrandEnabled;
            const checkbox = document.getElementById('concert-grand-toggle');
            if (checkbox) {
                checkbox.checked = concertGrandEnabled;
            }
            
            if (state.concertGrandPosition) {
                concertGrandPosition = {...state.concertGrandPosition};
            }
            
            const concertGrandSection = document.getElementById('concert-grand-section');
            if (concertGrandSection) {
                concertGrandSection.style.display = concertGrandEnabled ? 'block' : 'none';
                if (concertGrandEnabled) {
                    updateConcertGrandPosition();
                    if (!concertGrandSection.dataset.initialized) {
                        initializeConcertGrand();
                        concertGrandSection.dataset.initialized = 'true';
                    }
                }
            }
        }
        
        // Restore chorus
        if (state.chorusEnabled !== undefined) {
            chorusEnabled = state.chorusEnabled;
            const checkbox = document.getElementById('chorus-toggle');
            if (checkbox) {
                checkbox.checked = chorusEnabled;
            }
            
            if (state.chorusRows !== undefined) {
                chorusRows = state.chorusRows;
            }
            
            const chorusControls = document.getElementById('chorus-controls');
            if (chorusControls) {
                chorusControls.style.display = chorusEnabled ? 'block' : 'none';
            }
            
            if (chorusEnabled) {
                // Hide brass, woodwind, timpani risers
                hideBrassWoodwindTimpaniRisers();
                
                // Restore chorus risers
                if (state.chorusRisers && Array.isArray(state.chorusRisers)) {
                    chorusRisers = [];
                    state.chorusRisers.forEach(savedRiser => {
                        const config = riserConfigs['8x4'];
                        const riserData = {
                            id: savedRiser.id,
                            size: savedRiser.size || '8x4',
                            config: config,
                            x: savedRiser.x,
                            y: savedRiser.y,
                            dragging: false,
                            dragOffset: { x: 0, y: 0 },
                            number: savedRiser.number
                        };
                        
                        chorusRisers.push(riserData);
                        createChorusRiserElements(riserData);
                        initializeChorusRiser(riserData.id);
                    });
                }
                
                // Restore singers per row
                if (state.chorusSingersPerRow && Array.isArray(state.chorusSingersPerRow)) {
                    chorusSingersPerRow = [...state.chorusSingersPerRow];
                }
                
                // Restore chorus singers
                if (state.chorusSingers && Array.isArray(state.chorusSingers)) {
                    chorusSingers = [];
                    state.chorusSingers.forEach(savedSinger => {
                        const singerData = {
                            id: savedSinger.id,
                            rowIndex: savedSinger.rowIndex,
                            x: savedSinger.x,
                            y: savedSinger.y,
                            size: savedSinger.size
                        };
                        
                        chorusSingers.push(singerData);
                        createSingerElement(singerData);
                    });
                }
                
                updateChorusRowInputs();
                updateChorusRowCount();
                updateTotalSingersCount();
            }
        }
        
        if (state.timpaniRiserPosition) {
            timpaniRiserPosition = {...state.timpaniRiserPosition};
            updateTimpaniRiserPosition();
        }
        
        if (state.brassRiserPositions) {
            brassRiserPositions = {...state.brassRiserPositions};
            Object.keys(brassRiserPositions).forEach(riserId => {
                updateBrassRiserPosition(riserId);
            });
        }
        
        if (state.woodwindRiserPositions) {
            woodwindRiserPositions = {...state.woodwindRiserPositions};
            Object.keys(woodwindRiserPositions).forEach(riserId => {
                updateWoodwindRiserPosition(riserId);
            });
        }
        
        // Restore extra risers (user-added risers)
        if (state.extraRisers && Array.isArray(state.extraRisers)) {
            // Clear existing extra risers
            extraRisers.forEach(riserData => {
                const riserElement = document.getElementById(riserData.id);
                const labelElement = document.getElementById(riserData.id + '-label');
                if (riserElement) riserElement.remove();
                if (labelElement) labelElement.remove();
            });
            extraRisers = [];
            
            // Restore each extra riser
            state.extraRisers.forEach(savedRiser => {
                const config = riserConfigs[savedRiser.size];
                if (config) {
                    const riserData = {
                        id: savedRiser.id,
                        size: savedRiser.size,
                        config: config,
                        x: savedRiser.x,
                        y: savedRiser.y,
                        dragging: false,
                        dragOffset: { x: 0, y: 0 },
                        number: savedRiser.number || parseInt(savedRiser.id.match(/extra-riser-(\d+)/)?.[1] || '0', 10)
                    };
                    
                    extraRisers.push(riserData);
                    
                    // Create SVG elements
                    createRiserElements(riserData);
                    
                    // Initialize drag functionality
                    initializeExtraRiser(riserData.id);
                }
            });
            
            // Update counter display
            updateExtraRiserCount();
        }
        
        // Restore percussion blob
        if (state.percussionBlob) {
            percussionBlob.enabled = state.percussionBlob.enabled !== false;
            percussionBlob.targetArea = state.percussionBlob.targetArea || 0;
            percussionBlob.center = state.percussionBlob.center || { x: 200, y: 200 };
            percussionBlob.controlPoints = state.percussionBlob.controlPoints || [];
            percussionBlob.actualArea = calculateBlobArea(percussionBlob.controlPoints);
            renderPercussionBlob();
            updateBlobControlsVisibility();
        }
        
        // Restore riser visibility
        if (state.riserVisibility) {
            // Timpani riser
            if (state.riserVisibility.timpaniRiser !== undefined) {
                document.getElementById('timpani-riser-checkbox').checked = state.riserVisibility.timpaniRiser;
                toggleTimpaniRiser();
            }
            
            // Brass risers
            if (state.riserVisibility.brassRisers) {
                Object.keys(state.riserVisibility.brassRisers).forEach(riserId => {
                    const checkbox = document.getElementById(riserId + '-checkbox');
                    if (checkbox) {
                        checkbox.checked = state.riserVisibility.brassRisers[riserId];
                        toggleBrassRiser(riserId);
                    }
                });
            }
            
            // Woodwind risers
            if (state.riserVisibility.woodwindRisers) {
                Object.keys(state.riserVisibility.woodwindRisers).forEach(riserId => {
                    const checkbox = document.getElementById(riserId + '-checkbox');
                    if (checkbox) {
                        checkbox.checked = state.riserVisibility.woodwindRisers[riserId];
                        toggleWoodwindRiser(riserId);
                    }
                });
            }
            
            // Stage extensions
            if (state.riserVisibility.stageExtensions) {
                Object.keys(state.riserVisibility.stageExtensions).forEach(extensionId => {
                    const checkbox = document.getElementById(extensionId + '-checkbox');
                    if (checkbox) {
                        checkbox.checked = state.riserVisibility.stageExtensions[extensionId];
                        toggleStageExtension(extensionId);
                    }
                });
            }
        }
        
        // Restore debug mode
        if (state.debugMode !== undefined && state.debugMode !== debugMode) {
            toggleDebugMode();
        }
        
        // Recalculate and update display
        calculateSpace();
        updateStagePlot(true); // Skip position clearing when restoring from saved state
        
        // Show success message
        alert('Stage plot configuration loaded successfully!');
        
    } catch (error) {
        alert('Error loading configuration: ' + error.message);
        console.error('Error restoring state:', error);
    }
}

// Extra Risers Management
let extraRisers = [];

// Helper function to get the next available riser number based on existing risers
function getNextRiserNumber() {
    if (extraRisers.length === 0) {
        return 1;
    }
    
    // Extract all existing riser numbers
    const existingNumbers = extraRisers.map(riser => {
        const match = riser.id.match(/extra-riser-(\d+)/);
        return match ? parseInt(match[1], 10) : 0;
    });
    
    // Find the highest number and add 1
    const maxNumber = Math.max(...existingNumbers);
    return maxNumber + 1;
}

// Riser size configurations (15 pixels = 1 foot)
const riserConfigs = {
    '8x4': {
        width: 120, height: 60,
        fill: '#6b7280', stroke: '#4b5563',
        name: 'RISER'
    },
    '4x4': {
        width: 60, height: 60,
        fill: '#6b7280', stroke: '#4b5563',
        name: 'RISER'
    },
    '8x3': {
        width: 120, height: 45,
        fill: '#6b7280', stroke: '#4b5563',
        name: 'RISER'
    }
};

function addNewRiser() {
    const sizeSelect = document.getElementById('riser-size-select');
    const riserSize = sizeSelect.value;
    
    const riserNumber = getNextRiserNumber();
    const riserId = `extra-riser-${riserNumber}`;
    
    const config = riserConfigs[riserSize];
    
    // Create riser data
    const riserData = {
        id: riserId,
        size: riserSize,
        config: config,
        x: 400, // Default position
        y: 400,
        dragging: false,
        dragOffset: { x: 0, y: 0 },
        number: riserNumber // Store the number for the label
    };
    
    extraRisers.push(riserData);
    
    // Create SVG elements
    createRiserElements(riserData);
    
    // Update counter display
    updateExtraRiserCount();
    
    // Initialize drag functionality
    initializeExtraRiser(riserId);
}

function createRiserElements(riserData) {
    const svg = document.querySelector('#extra-risers-section');
    
    // Create riser rectangle
    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('id', riserData.id);
    rect.setAttribute('x', riserData.x);
    rect.setAttribute('y', riserData.y);
    rect.setAttribute('width', riserData.config.width);
    rect.setAttribute('height', riserData.config.height);
    rect.setAttribute('fill', riserData.config.fill);
    rect.setAttribute('stroke', riserData.config.stroke);
    rect.setAttribute('stroke-width', '2');
    rect.setAttribute('data-riser-type', 'extra');
    rect.classList.add('riser-draggable');
    
    // Create label
    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('id', riserData.id + '-label');
    text.setAttribute('x', riserData.x + riserData.config.width / 2);
    text.setAttribute('y', riserData.y + riserData.config.height / 2 + 5);
    text.setAttribute('text-anchor', 'middle');
    text.setAttribute('fill', 'white');
    text.setAttribute('font-size', '10');
    text.setAttribute('font-weight', 'bold');
    text.classList.add('riser-label');
    // Extract number from ID or use stored number
    const riserNumber = riserData.number || parseInt(riserData.id.match(/extra-riser-(\d+)/)?.[1] || '0', 10);
    text.textContent = `${riserData.size.replace('x', '×')} #${riserNumber}`;
    
    svg.appendChild(rect);
    svg.appendChild(text);
}

function initializeExtraRiser(riserId) {
    const riser = document.getElementById(riserId);
    if (!riser) return;
    
    // Add event listeners
    riser.addEventListener('mousedown', function(e) {
        startExtraRiserDrag(e, riserId);
    });
    
    riser.addEventListener('touchstart', function(e) {
        e.preventDefault();
        startExtraRiserDrag(e.touches[0], riserId);
    });
    
    riser.addEventListener('click', function(e) {
        const riserData = extraRisers.find(r => r.id === riserId);
        if (!riserData || !riserData.dragging) {
            e.stopPropagation();
            selectObject(riserId, riserId);
        }
    });
}

function startExtraRiserDrag(e, riserId) {
    // Handle multi-selection with Ctrl/Cmd/Shift key
    if (e.ctrlKey || e.metaKey || e.shiftKey) {
        toggleRiserSelection(riserId);
        return; // Don't start dragging, just toggle selection
    }
    
    // If clicking on a non-selected riser, clear other selections
    if (!selectedRisers.has(riserId)) {
        clearRiserSelection();
        selectRiser(riserId);
    }
    
    const riserData = extraRisers.find(r => r.id === riserId);
    if (!riserData) return;
    
    riserData.dragging = true;
    
    // Add dragging class
    document.getElementById(riserId).classList.add('dragging');
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    riserData.dragOffset = {
        x: mouseX - riserData.x,
        y: mouseY - riserData.y
    };
    
    // Add global event listeners
    document.addEventListener('mousemove', handleExtraRiserDragMove);
    document.addEventListener('mouseup', handleExtraRiserDragEnd);
    document.addEventListener('touchmove', handleExtraRiserDragMove);
    document.addEventListener('touchend', handleExtraRiserDragEnd);
}

function handleExtraRiserDragMove(e) {
    const draggingRiser = extraRisers.find(r => r.dragging);
    if (!draggingRiser) return;
    
    e.preventDefault();
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    let newX = mouseX - draggingRiser.dragOffset.x;
    let newY = mouseY - draggingRiser.dragOffset.y;
    
    // Constrain to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000 - draggingRiser.config.width,
        top: 0,
        bottom: 940 - draggingRiser.config.height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Apply snap-to functionality
    const snapPosition = getSnapPosition(draggingRiser.id, newX, newY, draggingRiser.config.width, draggingRiser.config.height);
    newX = snapPosition.x;
    newY = snapPosition.y;
    
    // Update position
    draggingRiser.x = newX;
    draggingRiser.y = newY;
    updateExtraRiserPosition(draggingRiser);
}

function handleExtraRiserDragEnd(e) {
    const draggingRiser = extraRisers.find(r => r.dragging);
    if (!draggingRiser) return;
    
    draggingRiser.dragging = false;
    
    // Remove dragging class
    document.getElementById(draggingRiser.id).classList.remove('dragging');
    
    // Remove global event listeners
    document.removeEventListener('mousemove', handleExtraRiserDragMove);
    document.removeEventListener('mouseup', handleExtraRiserDragEnd);
    document.removeEventListener('touchmove', handleExtraRiserDragMove);
    document.removeEventListener('touchend', handleExtraRiserDragEnd);
}

function updateExtraRiserPosition(riserData) {
    const riserElement = document.getElementById(riserData.id);
    const labelElement = document.getElementById(riserData.id + '-label');
    
    if (riserElement) {
        riserElement.setAttribute('x', riserData.x);
        riserElement.setAttribute('y', riserData.y);
    }
    
    if (labelElement) {
        labelElement.setAttribute('x', riserData.x + riserData.config.width / 2);
        labelElement.setAttribute('y', riserData.y + riserData.config.height / 2 + 5);
    }
}

function removeLastRiser() {
    if (extraRisers.length === 0) return;
    
    const lastRiser = extraRisers.pop();
    
    // Remove SVG elements
    const riserElement = document.getElementById(lastRiser.id);
    const labelElement = document.getElementById(lastRiser.id + '-label');
    
    if (riserElement) riserElement.remove();
    if (labelElement) labelElement.remove();
    
    updateExtraRiserCount();
}

function updateExtraRiserCount() {
    const countElement = document.getElementById('extra-riser-count');
    if (countElement) {
        countElement.textContent = `Extra risers: ${extraRisers.length}`;
    }
}



// Add event listeners to all inputs
document.addEventListener('DOMContentLoaded', function() {
    // Initialize use default seating checkbox
    const useDefaultSeatingCheckbox = document.getElementById('use-default-seating');
    if (useDefaultSeatingCheckbox) {
        useDefaultSeatingCheckbox.addEventListener('change', function() {
            useDefaultSeating = this.checked;
        });
    }
    
    // Static instruments
    staticInstruments.forEach(instrument => {
        addInstrumentEventListeners(instrument);
    });
    
    // Initialize podium
    initializePodium();
    
    // Initialize timpani riser
    initializeTimpaniRiser();
    
    // Initialize brass risers
    initializeBrassRisers();
    
    // Initialize woodwind risers
    initializeWoodwindRisers();
    
    // Initialize riser visibility
    toggleTimpaniRiser();
    
    // Initialize brass riser visibility
    const brassRiserIds = ['brass-riser-1', 'brass-riser-2', 'brass-riser-3', 'brass-riser-4', 'brass-riser-5'];
    brassRiserIds.forEach(riserId => {
        toggleBrassRiser(riserId);
    });
    
    // Initialize woodwind riser visibility
    const woodwindRiserIds = ['woodwind-riser-1', 'woodwind-riser-2', 'woodwind-riser-3', 'woodwind-riser-4'];
    woodwindRiserIds.forEach(riserId => {
        toggleWoodwindRiser(riserId);
    });
    
    // Add click event to stage plot for clearing selection
    const stagePlot = document.querySelector('.stage-plot');
    if (stagePlot) {
        stagePlot.addEventListener('click', function(e) {
            // Only clear selection if clicking on the SVG background
            if (e.target === stagePlot || e.target.classList.contains('stage-boundary')) {
                clearKeyboardSelection();
            }
        });
    }
    
    // Initialize multi-select
    initializeMultiSelect();
    
    // Initial calculations
    calculateSpace();
    
    // Initialize stage plot
    updateStagePlot();
    
    // Initialize percussion blob
    initializePercussionBlob();
});

// ============================================
// PERCUSSION BLOB - Deformable Shape System
// ============================================

// Percussion blob state
let percussionBlob = {
    enabled: true,
    targetArea: 0,          // Target area in sq ft (from instruments)
    actualArea: 0,          // Current calculated area
    center: { x: 200, y: 200 },
    controlPoints: [],      // Array of {x, y} points around the perimeter
    isDragging: false,
    dragPointIndex: -1,
    dragOffset: { x: 0, y: 0 }
};

const BLOB_MIN_POINTS = 6;
const BLOB_DEFAULT_POINTS = 8;
const BLOB_AREA_TOLERANCE = 2; // ±2 sq ft tolerance
const PIXELS_PER_SQFT = 15 * 15; // 15 pixels per foot, so 225 sq pixels per sq ft

// Initialize the percussion blob system
function initializePercussionBlob() {
    // Create the SVG group for the blob if it doesn't exist
    let blobGroup = document.getElementById('percussion-blob-group');
    if (!blobGroup) {
        const percussionSection = document.getElementById('percussion-section');
        if (percussionSection) {
            blobGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
            blobGroup.setAttribute('id', 'percussion-blob-group');
            percussionSection.appendChild(blobGroup);
        }
    }
    
    // Add event listeners for blob interaction
    document.addEventListener('mousemove', handleBlobDragMove);
    document.addEventListener('mouseup', handleBlobDragEnd);
    document.addEventListener('touchmove', handleBlobDragMove);
    document.addEventListener('touchend', handleBlobDragEnd);
}

// Calculate total percussion square footage
function calculatePercussionArea() {
    const percussionInstruments = ['timpani', 'snare', 'xylophone', 'marimba', 'cymbals', 
                                    'vibraphone', 'glockenspiel', 'chimes', 'bassDrum', 'cymbal'];
    let totalSqFt = 0;
    
    dynamicInstruments.forEach(instrumentId => {
        if (percussionInstruments.some(p => instrumentId.startsWith(p))) {
            const countElement = document.getElementById(instrumentId);
            const sqftElement = document.getElementById(instrumentId + '_sqft');
            
            if (countElement && sqftElement) {
                const count = parseInt(countElement.value) || 0;
                const sqft = parseFloat(sqftElement.value) || 0;
                totalSqFt += count * sqft;
            }
        }
    });
    
    return totalSqFt;
}

// Create initial blob shape (circular) with given area
function createInitialBlob(centerX, centerY, areaSqFt) {
    if (areaSqFt <= 0) {
        percussionBlob.controlPoints = [];
        return;
    }
    
    // Convert sq ft to sq pixels
    const areaPixels = areaSqFt * PIXELS_PER_SQFT;
    
    // Calculate radius for a circle with this area: A = πr², so r = √(A/π)
    const radius = Math.sqrt(areaPixels / Math.PI);
    
    // Create control points in a circle
    const points = [];
    for (let i = 0; i < BLOB_DEFAULT_POINTS; i++) {
        const angle = (i / BLOB_DEFAULT_POINTS) * 2 * Math.PI - Math.PI / 2; // Start from top
        points.push({
            x: centerX + radius * Math.cos(angle),
            y: centerY + radius * Math.sin(angle)
        });
    }
    
    percussionBlob.center = { x: centerX, y: centerY };
    percussionBlob.controlPoints = points;
    percussionBlob.targetArea = areaSqFt;
}

// Generate smooth SVG path using Catmull-Rom splines
function generateBlobPath(points) {
    if (points.length < 3) return '';
    
    const n = points.length;
    let path = '';
    
    // Catmull-Rom to Bezier conversion
    // For a closed curve, we need to wrap around
    for (let i = 0; i < n; i++) {
        const p0 = points[(i - 1 + n) % n];
        const p1 = points[i];
        const p2 = points[(i + 1) % n];
        const p3 = points[(i + 2) % n];
        
        // Catmull-Rom to cubic bezier control points
        const tension = 0.5; // Adjust for smoothness (0 = sharp, 1 = very smooth)
        
        const cp1x = p1.x + (p2.x - p0.x) * tension / 3;
        const cp1y = p1.y + (p2.y - p0.y) * tension / 3;
        const cp2x = p2.x - (p3.x - p1.x) * tension / 3;
        const cp2y = p2.y - (p3.y - p1.y) * tension / 3;
        
        if (i === 0) {
            path = `M ${p1.x.toFixed(1)} ${p1.y.toFixed(1)}`;
        }
        
        path += ` C ${cp1x.toFixed(1)} ${cp1y.toFixed(1)}, ${cp2x.toFixed(1)} ${cp2y.toFixed(1)}, ${p2.x.toFixed(1)} ${p2.y.toFixed(1)}`;
    }
    
    path += ' Z'; // Close the path
    return path;
}

// Calculate area of the blob using numerical integration (shoelace formula approximation)
function calculateBlobArea(points) {
    if (points.length < 3) return 0;
    
    // Generate many points along the bezier path for accurate area calculation
    const sampledPoints = sampleBlobPath(points, 100);
    
    // Shoelace formula
    let area = 0;
    const n = sampledPoints.length;
    for (let i = 0; i < n; i++) {
        const j = (i + 1) % n;
        area += sampledPoints[i].x * sampledPoints[j].y;
        area -= sampledPoints[j].x * sampledPoints[i].y;
    }
    area = Math.abs(area) / 2;
    
    // Convert to square feet
    return area / PIXELS_PER_SQFT;
}

// Sample points along the bezier path
function sampleBlobPath(controlPoints, numSamples) {
    if (controlPoints.length < 3) return [];
    
    const sampledPoints = [];
    const n = controlPoints.length;
    const samplesPerSegment = Math.ceil(numSamples / n);
    
    for (let i = 0; i < n; i++) {
        const p0 = controlPoints[(i - 1 + n) % n];
        const p1 = controlPoints[i];
        const p2 = controlPoints[(i + 1) % n];
        const p3 = controlPoints[(i + 2) % n];
        
        const tension = 0.5;
        
        const cp1x = p1.x + (p2.x - p0.x) * tension / 3;
        const cp1y = p1.y + (p2.y - p0.y) * tension / 3;
        const cp2x = p2.x - (p3.x - p1.x) * tension / 3;
        const cp2y = p2.y - (p3.y - p1.y) * tension / 3;
        
        // Sample along this bezier segment
        for (let t = 0; t < 1; t += 1 / samplesPerSegment) {
            const point = cubicBezierPoint(p1, {x: cp1x, y: cp1y}, {x: cp2x, y: cp2y}, p2, t);
            sampledPoints.push(point);
        }
    }
    
    return sampledPoints;
}

// Calculate point on cubic bezier curve at parameter t
function cubicBezierPoint(p0, p1, p2, p3, t) {
    const t2 = t * t;
    const t3 = t2 * t;
    const mt = 1 - t;
    const mt2 = mt * mt;
    const mt3 = mt2 * mt;
    
    return {
        x: mt3 * p0.x + 3 * mt2 * t * p1.x + 3 * mt * t2 * p2.x + t3 * p3.x,
        y: mt3 * p0.y + 3 * mt2 * t * p1.y + 3 * mt * t2 * p2.y + t3 * p3.y
    };
}

// Scale blob to match target area
function scaleBlobToArea(targetAreaSqFt) {
    if (percussionBlob.controlPoints.length < 3) return;
    
    const currentArea = calculateBlobArea(percussionBlob.controlPoints);
    if (currentArea <= 0) return;
    
    // Check if we're within tolerance
    if (Math.abs(currentArea - targetAreaSqFt) <= BLOB_AREA_TOLERANCE) {
        percussionBlob.actualArea = currentArea;
        return;
    }
    
    // Calculate scale factor (area scales with square of linear scale)
    const scaleFactor = Math.sqrt(targetAreaSqFt / currentArea);
    
    // Find centroid
    let cx = 0, cy = 0;
    percussionBlob.controlPoints.forEach(p => {
        cx += p.x;
        cy += p.y;
    });
    cx /= percussionBlob.controlPoints.length;
    cy /= percussionBlob.controlPoints.length;
    
    // Scale all points from centroid
    percussionBlob.controlPoints = percussionBlob.controlPoints.map(p => ({
        x: cx + (p.x - cx) * scaleFactor,
        y: cy + (p.y - cy) * scaleFactor
    }));
    
    percussionBlob.center = { x: cx, y: cy };
    percussionBlob.actualArea = targetAreaSqFt;
}

// Render the percussion blob
function renderPercussionBlob() {
    // Ensure blob group exists (create if needed)
    let blobGroup = document.getElementById('percussion-blob-group');
    if (!blobGroup) {
        const percussionSection = document.getElementById('percussion-section');
        if (percussionSection) {
            blobGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
            blobGroup.setAttribute('id', 'percussion-blob-group');
            percussionSection.appendChild(blobGroup);
        }
    }
    
    if (!blobGroup) return;
    
    // Clear existing blob elements
    blobGroup.innerHTML = '';
    
    // If no percussion or blob disabled, don't render
    if (!percussionBlob.enabled || percussionBlob.controlPoints.length < 3) {
        return;
    }
    
    // Create the blob path
    const pathData = generateBlobPath(percussionBlob.controlPoints);
    
    // Create blob fill
    const blobPath = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    blobPath.setAttribute('id', 'percussion-blob-path');
    blobPath.setAttribute('d', pathData);
    blobPath.setAttribute('fill', 'rgba(139, 92, 246, 0.3)'); // Purple with transparency
    blobPath.setAttribute('stroke', '#8b5cf6');
    blobPath.setAttribute('stroke-width', '2');
    blobPath.setAttribute('cursor', 'move');
    blobPath.classList.add('percussion-blob');
    
    // Make the entire blob draggable (to move it)
    blobPath.addEventListener('mousedown', startBlobMove);
    blobPath.addEventListener('touchstart', startBlobMove);
    
    blobGroup.appendChild(blobPath);
    
    // Create control points (handles)
    percussionBlob.controlPoints.forEach((point, index) => {
        const handle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        handle.setAttribute('cx', point.x);
        handle.setAttribute('cy', point.y);
        handle.setAttribute('r', '6');
        handle.setAttribute('fill', '#8b5cf6');
        handle.setAttribute('stroke', 'white');
        handle.setAttribute('stroke-width', '2');
        handle.setAttribute('cursor', 'pointer');
        handle.setAttribute('data-point-index', index);
        handle.classList.add('blob-control-point');
        
        handle.addEventListener('mousedown', (e) => startBlobPointDrag(e, index));
        handle.addEventListener('touchstart', (e) => startBlobPointDrag(e, index));
        
        blobGroup.appendChild(handle);
    });
    
    // Add label in center
    const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    label.setAttribute('x', percussionBlob.center.x);
    label.setAttribute('y', percussionBlob.center.y);
    label.setAttribute('text-anchor', 'middle');
    label.setAttribute('dominant-baseline', 'middle');
    label.setAttribute('fill', '#5b21b6');
    label.setAttribute('font-size', '12');
    label.setAttribute('font-weight', 'bold');
    label.setAttribute('pointer-events', 'none');
    label.textContent = `PERC (${percussionBlob.actualArea.toFixed(0)} sq ft)`;
    blobGroup.appendChild(label);
}

// Start dragging a control point
function startBlobPointDrag(e, pointIndex) {
    e.preventDefault();
    e.stopPropagation();
    
    percussionBlob.isDragging = true;
    percussionBlob.dragPointIndex = pointIndex;
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const scaleX = svg.viewBox.baseVal.width / rect.width;
    const scaleY = svg.viewBox.baseVal.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    const point = percussionBlob.controlPoints[pointIndex];
    percussionBlob.dragOffset = {
        x: mouseX - point.x,
        y: mouseY - point.y
    };
}

// Start moving the entire blob
let blobMoveStart = null;
function startBlobMove(e) {
    if (e.target.classList.contains('blob-control-point')) return; // Don't move when dragging a point
    
    e.preventDefault();
    e.stopPropagation();
    
    percussionBlob.isDragging = true;
    percussionBlob.dragPointIndex = -1; // -1 means moving entire blob
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const scaleX = svg.viewBox.baseVal.width / rect.width;
    const scaleY = svg.viewBox.baseVal.height / rect.height;
    
    blobMoveStart = {
        x: (clientX - rect.left) * scaleX,
        y: (clientY - rect.top) * scaleY
    };
}

// Handle blob drag move
function handleBlobDragMove(e) {
    if (!percussionBlob.isDragging) return;
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const scaleX = svg.viewBox.baseVal.width / rect.width;
    const scaleY = svg.viewBox.baseVal.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    if (percussionBlob.dragPointIndex >= 0) {
        // Dragging a control point
        const newX = mouseX - percussionBlob.dragOffset.x;
        const newY = mouseY - percussionBlob.dragOffset.y;
        
        // Update the point position
        percussionBlob.controlPoints[percussionBlob.dragPointIndex] = { x: newX, y: newY };
        
        // Scale to maintain area
        scaleBlobToArea(percussionBlob.targetArea);
        
        // Re-render
        renderPercussionBlob();
    } else if (blobMoveStart) {
        // Moving entire blob
        const dx = mouseX - blobMoveStart.x;
        const dy = mouseY - blobMoveStart.y;
        
        // Move all points
        percussionBlob.controlPoints = percussionBlob.controlPoints.map(p => ({
            x: p.x + dx,
            y: p.y + dy
        }));
        
        percussionBlob.center.x += dx;
        percussionBlob.center.y += dy;
        
        blobMoveStart = { x: mouseX, y: mouseY };
        
        // Re-render
        renderPercussionBlob();
    }
}

// Handle blob drag end
function handleBlobDragEnd(e) {
    if (!percussionBlob.isDragging) return;
    
    percussionBlob.isDragging = false;
    percussionBlob.dragPointIndex = -1;
    blobMoveStart = null;
    
    // Final scale to ensure area is correct
    scaleBlobToArea(percussionBlob.targetArea);
    renderPercussionBlob();
    
    // Update debug info
    if (debugMode) {
        updateDebugInfo();
    }
}

// Add a new control point to the blob (click on perimeter)
function addBlobControlPoint(x, y) {
    if (percussionBlob.controlPoints.length < 3) return;
    
    // Find the closest segment to insert the new point
    let minDist = Infinity;
    let insertIndex = 0;
    
    const n = percussionBlob.controlPoints.length;
    for (let i = 0; i < n; i++) {
        const p1 = percussionBlob.controlPoints[i];
        const p2 = percussionBlob.controlPoints[(i + 1) % n];
        
        // Distance from point to line segment
        const dist = pointToSegmentDistance(x, y, p1.x, p1.y, p2.x, p2.y);
        
        if (dist < minDist) {
            minDist = dist;
            insertIndex = i + 1;
        }
    }
    
    // Insert the new point
    percussionBlob.controlPoints.splice(insertIndex, 0, { x, y });
    
    // Scale to maintain area
    scaleBlobToArea(percussionBlob.targetArea);
    
    // Re-render
    renderPercussionBlob();
}

// Helper: distance from point to line segment
function pointToSegmentDistance(px, py, x1, y1, x2, y2) {
    const dx = x2 - x1;
    const dy = y2 - y1;
    const len2 = dx * dx + dy * dy;
    
    if (len2 === 0) return Math.sqrt((px - x1) ** 2 + (py - y1) ** 2);
    
    let t = ((px - x1) * dx + (py - y1) * dy) / len2;
    t = Math.max(0, Math.min(1, t));
    
    const nearX = x1 + t * dx;
    const nearY = y1 + t * dy;
    
    return Math.sqrt((px - nearX) ** 2 + (py - nearY) ** 2);
}

// Update the percussion blob (called when instruments change)
function updatePercussionBlob() {
    const totalArea = calculatePercussionArea();
    
    if (totalArea <= 0) {
        // No percussion instruments, clear the blob
        percussionBlob.controlPoints = [];
        percussionBlob.targetArea = 0;
        percussionBlob.actualArea = 0;
        renderPercussionBlob();
        updateBlobControlsVisibility();
        return;
    }
    
    if (percussionBlob.controlPoints.length < 3) {
        // Create initial blob
        createInitialBlob(200, 200, totalArea);
    } else {
        // Resize existing blob proportionally
        percussionBlob.targetArea = totalArea;
        scaleBlobToArea(totalArea);
    }
    
    percussionBlob.actualArea = calculateBlobArea(percussionBlob.controlPoints);
    renderPercussionBlob();
    updateBlobControlsVisibility();
}

// Check if a point is inside the blob (for collision detection)
function isPointInsideBlob(x, y) {
    if (percussionBlob.controlPoints.length < 3) return false;
    
    // Sample the blob path
    const sampledPoints = sampleBlobPath(percussionBlob.controlPoints, 50);
    
    // Ray casting algorithm
    let inside = false;
    const n = sampledPoints.length;
    for (let i = 0, j = n - 1; i < n; j = i++) {
        const xi = sampledPoints[i].x, yi = sampledPoints[i].y;
        const xj = sampledPoints[j].x, yj = sampledPoints[j].y;
        
        if (((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) {
            inside = !inside;
        }
    }
    
    return inside;
}

// Check if a circle collides with the blob
function circleCollidesWithBlob(cx, cy, radius) {
    if (percussionBlob.controlPoints.length < 3) return false;
    
    // Check if center is inside blob
    if (isPointInsideBlob(cx, cy)) return true;
    
    // Check if any point on the circle's perimeter is inside the blob
    for (let angle = 0; angle < 2 * Math.PI; angle += Math.PI / 8) {
        const px = cx + radius * Math.cos(angle);
        const py = cy + radius * Math.sin(angle);
        if (isPointInsideBlob(px, py)) return true;
    }
    
    // Check if any blob edge is within radius of center
    const sampledPoints = sampleBlobPath(percussionBlob.controlPoints, 50);
    for (const point of sampledPoints) {
        const dist = Math.sqrt((point.x - cx) ** 2 + (point.y - cy) ** 2);
        if (dist < radius) return true;
    }
    
    return false;
}

// Add a vertex to the blob (interpolate between existing points)
function addBlobVertex() {
    if (percussionBlob.controlPoints.length < 3) return;
    
    const n = percussionBlob.controlPoints.length;
    const newPoints = [];
    
    // Find the longest edge and insert a point there
    let maxDist = 0;
    let maxIndex = 0;
    
    for (let i = 0; i < n; i++) {
        const p1 = percussionBlob.controlPoints[i];
        const p2 = percussionBlob.controlPoints[(i + 1) % n];
        const dist = Math.sqrt((p2.x - p1.x) ** 2 + (p2.y - p1.y) ** 2);
        if (dist > maxDist) {
            maxDist = dist;
            maxIndex = i;
        }
    }
    
    // Insert new point at midpoint of longest edge
    for (let i = 0; i < n; i++) {
        newPoints.push(percussionBlob.controlPoints[i]);
        if (i === maxIndex) {
            const p1 = percussionBlob.controlPoints[i];
            const p2 = percussionBlob.controlPoints[(i + 1) % n];
            newPoints.push({
                x: (p1.x + p2.x) / 2,
                y: (p1.y + p2.y) / 2
            });
        }
    }
    
    percussionBlob.controlPoints = newPoints;
    
    // Scale to maintain area
    scaleBlobToArea(percussionBlob.targetArea);
    
    // Update UI and render
    updateBlobVertexCount();
    renderPercussionBlob();
}

// Remove a vertex from the blob
function removeBlobVertex() {
    if (percussionBlob.controlPoints.length <= BLOB_MIN_POINTS) {
        return; // Can't go below minimum
    }
    
    const n = percussionBlob.controlPoints.length;
    
    // Find the shortest edge and remove the point that's part of the two shortest edges
    let shortestEdgeSum = Infinity;
    let removeIndex = 0;
    
    for (let i = 0; i < n; i++) {
        const prevIdx = (i - 1 + n) % n;
        const nextIdx = (i + 1) % n;
        
        const p0 = percussionBlob.controlPoints[prevIdx];
        const p1 = percussionBlob.controlPoints[i];
        const p2 = percussionBlob.controlPoints[nextIdx];
        
        const dist1 = Math.sqrt((p1.x - p0.x) ** 2 + (p1.y - p0.y) ** 2);
        const dist2 = Math.sqrt((p2.x - p1.x) ** 2 + (p2.y - p1.y) ** 2);
        const edgeSum = dist1 + dist2;
        
        if (edgeSum < shortestEdgeSum) {
            shortestEdgeSum = edgeSum;
            removeIndex = i;
        }
    }
    
    // Remove the point
    percussionBlob.controlPoints.splice(removeIndex, 1);
    
    // Scale to maintain area
    scaleBlobToArea(percussionBlob.targetArea);
    
    // Update UI and render
    updateBlobVertexCount();
    renderPercussionBlob();
}

// Update the vertex count display
function updateBlobVertexCount() {
    const countElement = document.getElementById('blobVertexCount');
    if (countElement) {
        countElement.textContent = percussionBlob.controlPoints.length;
    }
}

// Show/hide blob controls based on whether percussion exists
function updateBlobControlsVisibility() {
    const blobControls = document.getElementById('blobControls');
    if (blobControls) {
        if (percussionBlob.controlPoints.length > 0) {
            blobControls.style.display = 'block';
            updateBlobVertexCount();
        } else {
            blobControls.style.display = 'none';
        }
    }
}
