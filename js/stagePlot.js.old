        { x: 832, y: 220 },  // Cb-8
        { x: 832, y: 180 },  // Cb-9
        { x: 832, y: 140 },  // Cb-10
        { x: 810, y: 120 },  // Cb-11
        { x: 790, y: 100 },  // Cb-12
        { x: 770, y: 80 },   // Cb-13
        { x: 750, y: 60 },   // Cb-14
        { x: 730, y: 80 },   // Cb-15
        { x: 710, y: 100 },  // Cb-16
        { x: 690, y: 120 },  // Cb-17
        { x: 670, y: 140 },  // Cb-18
        { x: 650, y: 160 },  // Cb-19
        { x: 630, y: 180 },  // Cb-20
    ];
    
    for (let i = 0; i < count && i < positions.length; i++) {
        let pos = positions[i];
        
        // If concert grand is enabled, shift 3 feet upstage (45px up = -45 Y)
        if (concertGrandEnabled) {
            pos = { x: pos.x, y: pos.y - 45 };
        }
        
        const playerId = `bass-${i + 1}`;
        const label = `Cb-${i + 1}`;
        
        createPlayer(section, 'bass-player', playerId, pos, label, instrumentType);
    }
}

function updateDynamicInstruments() {
    // Update woodwinds section
    updateWoodwindsSection();
    
    // Update percussion section
    updatePercussionSection();
    
    // Update keyboard section
    updateKeyboardSection();
}

function updateWoodwindsSection() {
    const section = document.getElementById('woodwinds-section');
    
    // Define specific positions for woodwind players
    const specificWoodwindPositions = {
        'flute-1': { x: 410.0, y: 335.0 },
        'flute-2': { x: 470.0, y: 335.0 },
        'oboe-1': { x: 590.0, y: 335.0 },
        'oboe-2': { x: 530.0, y: 335.0 },
        'clarinet-1': { x: 410.0, y: 274.0 },
        'clarinet-2': { x: 470.0, y: 274.0 },
        'bassoon-1': { x: 588.8, y: 274.0 },
        'bassoon-2': { x: 530.0, y: 274.0 }
    };
    
    // Define fallback woodwinds positions (stage right, upstage area)
    const woodwindsPositions = [
        { x: 300, y: 150 },   // Position 1
        { x: 320, y: 170 },   // Position 2
        { x: 340, y: 190 },   // Position 3
        { x: 360, y: 210 },   // Position 4
        { x: 380, y: 230 },   // Position 5
        { x: 400, y: 250 },   // Position 6
        { x: 420, y: 270 },   // Position 7
        { x: 440, y: 290 },   // Position 8
        { x: 460, y: 310 },   // Position 9
        { x: 480, y: 330 },   // Position 10
        { x: 280, y: 200 },   // Position 11
        { x: 260, y: 220 },   // Position 12
        { x: 240, y: 240 },   // Position 13
        { x: 220, y: 260 },   // Position 14
        { x: 200, y: 280 },   // Position 15
        { x: 180, y: 300 },   // Position 16
        { x: 160, y: 320 },   // Position 17
        { x: 140, y: 340 },   // Position 18
        { x: 120, y: 360 },   // Position 19
        { x: 100, y: 380 },   // Position 20
    ];
    
    let positionIndex = 0;
    
    // Handle static woodwind instruments
    const staticWoodwinds = ['flute', 'oboe', 'clarinet', 'bassoon'];
    staticWoodwinds.forEach(instrumentType => {
        const count = parseInt(document.getElementById(instrumentType).value) || 0;
        
        for (let i = 0; i < count; i++) {
            const playerId = `${instrumentType}-${i + 1}`;
            const label = `${instrumentType.charAt(0).toUpperCase() + instrumentType.slice(1)}-${i + 1}`;
            
            // Check if there's a specific position for this player
            let pos;
            if (specificWoodwindPositions[playerId]) {
                pos = specificWoodwindPositions[playerId];
            } else if (positionIndex < woodwindsPositions.length) {
                pos = woodwindsPositions[positionIndex];
                positionIndex++;
            } else {
                // Fallback to a default position if we run out of positions
                pos = { x: 300 + (positionIndex * 30), y: 400 };
                positionIndex++;
            }
            
            createPlayer(section, 'woodwind-player', playerId, pos, label, instrumentType);
        }
    });
    
    // Handle dynamic woodwind instruments (excluding the static ones)
    const dynamicWoodwinds = ['saxophone', 'frenchhorn', 'trumpet', 'cornet', 'trombone', 'tuba'];
    
    dynamicInstruments.forEach(instrumentId => {
        if (dynamicWoodwinds.some(w => instrumentId.startsWith(w))) {
            const count = parseInt(document.getElementById(instrumentId).value) || 0;
            const instrumentName = instrumentId.split('_')[0]; // Get base instrument name
            
            for (let i = 0; i < count; i++) {
                const playerId = `${instrumentId}-${i + 1}`;
                const label = `${instrumentName.charAt(0).toUpperCase() + instrumentName.slice(1)}-${i + 1}`;
                
                let pos;
                if (positionIndex < woodwindsPositions.length) {
                    pos = woodwindsPositions[positionIndex];
                    positionIndex++;
                } else {
                    // Fallback to a default position if we run out of positions
                    pos = { x: 300 + (positionIndex * 30), y: 400 };
                    positionIndex++;
                }
                
                createPlayer(section, 'woodwind-player', playerId, pos, label, instrumentId);
            }
        }
    });
}

function updatePercussionSection() {
    const section = document.getElementById('percussion-section');
    
    // Clear existing percussion players (we'll use the blob instead)
    if (section) {
        // Remove individual percussion players, keep the blob group
        const elementsToRemove = section.querySelectorAll('circle[data-player-id], text.player-label');
        elementsToRemove.forEach(el => {
            if (!el.classList.contains('blob-control-point')) {
                el.remove();
            }
        });
    }
    
    // Update the percussion blob
    updatePercussionBlob();
    
    // OLD CODE - kept for reference but no longer executed
    return;
    
    // Define percussion positions (stage right, back area)
    const percussionPositions = [
        { x: 150, y: 100 },   // Position 1
