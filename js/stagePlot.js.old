    if (riser && riserLabel) {
        const pos = woodwindRiserPositions[riserId];
        riser.setAttribute('x', pos.x);
        riser.setAttribute('y', pos.y);
        
        // Center the label in the riser
        riserLabel.setAttribute('x', pos.x + 60); // Half of 120
        riserLabel.setAttribute('y', pos.y + 35); // Slightly below center
    }
}

function resetWoodwindRiserPositions() {
    // Reset to default positions
    woodwindRiserPositions = {
        'woodwind-riser-1': { x: 380, y: 245 },
        'woodwind-riser-2': { x: 500, y: 245 },
        'woodwind-riser-3': { x: 380, y: 305 },
        'woodwind-riser-4': { x: 500, y: 305 }
    };
    
    Object.keys(woodwindRiserPositions).forEach(riserId => {
        updateWoodwindRiserPosition(riserId);
    });
}

function toggleWoodwindRiser(riserId) {
    const checkbox = document.getElementById(riserId + '-checkbox');
    const riser = document.getElementById(riserId);
    const riserLabel = document.getElementById(riserId + '-label');
    
    if (checkbox.checked) {
        // If chorus is enabled, place riser off to the side for manual placement
        if (chorusEnabled) {
            // Place woodwind risers in a grid off to the right side
            const riserNumber = parseInt(riserId.match(/\d+/)[0]);
            const row = Math.floor((riserNumber - 1) / 2); // 2 risers per row
            const col = (riserNumber - 1) % 2;
            woodwindRiserPositions[riserId] = { 
                x: 700 + (col * 140), // 140px spacing horizontally, on right side
                y: 200 + (row * 80)   // 80px spacing vertically
            };
            updateWoodwindRiserPosition(riserId);
        }
        riser.style.display = 'block';
        riserLabel.style.display = 'block';
    } else {
        riser.style.display = 'none';
        riserLabel.style.display = 'none';
    }
}

function startTimpaniRiserDrag(e) {
    const riserId = 'timpani-riser';
    
    // Handle multi-selection with Ctrl/Cmd/Shift key
    if (e.ctrlKey || e.metaKey || e.shiftKey) {
        toggleRiserSelection(riserId);
        return; // Don't start dragging, just toggle selection
    }
    
    // If clicking on a non-selected riser, clear other selections
    if (!selectedRisers.has(riserId)) {
        clearRiserSelection();
        selectRiser(riserId);
    }
    
    // Check if we're starting a group drag
    if (selectedRisers.size > 1) {
        isGroupDraggingRisers = true;
    }
    
    timpaniRiserDragging = true;
    
    // Add dragging class
    document.getElementById('timpani-riser').classList.add('dragging');
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    timpaniRiserDragOffset = {
        x: mouseX - timpaniRiserPosition.x,
        y: mouseY - timpaniRiserPosition.y
    };

    // If group dragging, calculate offsets for all selected risers
    if (isGroupDraggingRisers) {
        groupRiserDragOffsets.clear();
        selectedRisers.forEach(id => {
            const riser = document.getElementById(id);
            if (riser && riser.getAttribute('data-riser-type')) {
                let riserX, riserY;
                if (id.startsWith('brass-riser-')) {
                    riserX = brassRiserPositions[id].x;
                    riserY = brassRiserPositions[id].y;
                } else if (id.startsWith('woodwind-riser-')) {
                    riserX = woodwindRiserPositions[id].x;
                    riserY = woodwindRiserPositions[id].y;
                } else if (id === 'timpani-riser') {
                    riserX = timpaniRiserPosition.x;
                    riserY = timpaniRiserPosition.y;
                }
                
                groupRiserDragOffsets.set(id, {
                    x: mouseX - riserX,
                    y: mouseY - riserY
                });
                riser.classList.add('dragging');
            }
        });
    }

    // Add global event listeners
    document.addEventListener('mousemove', handleTimpaniRiserDragMove);
    document.addEventListener('mouseup', handleTimpaniRiserDragEnd);
    document.addEventListener('touchmove', handleTimpaniRiserDragMove);
    document.addEventListener('touchend', handleTimpaniRiserDragEnd);
}

function handleTimpaniRiserDragMove(e) {
    if (!timpaniRiserDragging) return;

    e.preventDefault();
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    let newX = mouseX - timpaniRiserDragOffset.x;
    let newY = mouseY - timpaniRiserDragOffset.y;
    
    // Allow unrestricted movement anywhere on canvas
    // Constrain only to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000,  // SVG viewBox width
        top: 0,
        bottom: 940   // SVG viewBox height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Apply snap-to functionality only when not group dragging (to maintain relative positions)
    if (!isGroupDraggingRisers) {
        const riserWidth = 120; // timpani riser width
        const riserHeight = 120; // timpani riser height
        const snapPosition = getSnapPosition('timpani-riser', newX, newY, riserWidth, riserHeight);
        newX = snapPosition.x;
        newY = snapPosition.y;
    }
    
    // Update riser position
    timpaniRiserPosition = { x: newX, y: newY };
    updateTimpaniRiserPosition();
    
    // If group dragging, update all selected risers
    if (isGroupDraggingRisers) {
        selectedRisers.forEach(id => {
            if (id !== 'timpani-riser') {
                const offset = groupRiserDragOffsets.get(id);
                if (offset) {
                    let riserNewX = mouseX - offset.x;
                    let riserNewY = mouseY - offset.y;
                    
                    // Constrain to canvas boundaries
                    riserNewX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, riserNewX));
                    riserNewY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, riserNewY));
                    
                    // Update position based on riser type
                    if (id.startsWith('brass-riser-')) {
                        brassRiserPositions[id] = { x: riserNewX, y: riserNewY };
                        updateBrassRiserPosition(id);
                    } else if (id.startsWith('woodwind-riser-')) {
                        woodwindRiserPositions[id] = { x: riserNewX, y: riserNewY };
                        updateWoodwindRiserPosition(id);
                    } else if (id === 'timpani-riser') {
                        const timpaniRiser = document.getElementById('timpani-riser');
                        timpaniRiser.setAttribute('x', riserNewX);
                        timpaniRiser.setAttribute('y', riserNewY);
                        timpaniRiserPosition.x = riserNewX;
                        timpaniRiserPosition.y = riserNewY;
                    } else if (id.startsWith('extra-riser-')) {
                        const riserData = extraRisers.find(r => r.id === id);
                        if (riserData) {
                            riserData.x = riserNewX;
                            riserData.y = riserNewY;
                            updateExtraRiserPosition(riserData);
                        }
                    }
                }
            }
        });
    }
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function handleTimpaniRiserDragEnd(e) {
    if (timpaniRiserDragging) {
        // Remove dragging class from current riser
        document.getElementById('timpani-riser').classList.remove('dragging');
        
        // If group dragging, remove dragging class from all selected risers
        if (isGroupDraggingRisers) {
            selectedRisers.forEach(id => {
                const riser = document.getElementById(id);
                if (riser) {
                    riser.classList.remove('dragging');
                }
            });
            isGroupDraggingRisers = false;
            groupRiserDragOffsets.clear();
        }
        
        timpaniRiserDragging = false;
        timpaniRiserDragOffset = { x: 0, y: 0 };
    }

    // Prevent focus and blur any focused element to avoid blue box
    e.preventDefault();
    if (document.activeElement) {
        document.activeElement.blur();
    }

    // Remove global event listeners
    document.removeEventListener('mousemove', handleTimpaniRiserDragMove);
    document.removeEventListener('mouseup', handleTimpaniRiserDragEnd);
    document.removeEventListener('touchmove', handleTimpaniRiserDragMove);
    document.removeEventListener('touchend', handleTimpaniRiserDragEnd);
}

function updateTimpaniRiserPosition() {
    const timpaniRiser = document.getElementById('timpani-riser');
    const timpaniRiserLabel = document.getElementById('timpani-riser-label');
    
    if (timpaniRiser && timpaniRiserLabel) {
        timpaniRiser.setAttribute('x', timpaniRiserPosition.x);
        timpaniRiser.setAttribute('y', timpaniRiserPosition.y);
        
        // Center the label in the riser
        timpaniRiserLabel.setAttribute('x', timpaniRiserPosition.x + 60); // Half of 120
        timpaniRiserLabel.setAttribute('y', timpaniRiserPosition.y + 65); // Slightly below center
    }
}

function resetTimpaniRiserPosition() {
    // Reset to default position in upstage corner
    timpaniRiserPosition = { x: 260, y: 95 };
    updateTimpaniRiserPosition();
}

function toggleTimpaniRiser() {
    const checkbox = document.getElementById('timpani-riser-checkbox');
    const riserSection = document.getElementById('timpani-riser-section');
    
    if (checkbox.checked) {
        // If chorus is enabled, place riser off to the side for manual placement
        if (chorusEnabled) {
            timpaniRiserPosition = { x: 100, y: 800 }; // Off to the side, downstage
            updateTimpaniRiserPosition();
        }
        riserSection.style.display = 'block';
    } else {
        riserSection.style.display = 'none';
    }
}

function toggleBrassRiser(riserId) {
    const checkbox = document.getElementById(riserId + '-checkbox');
    const riser = document.getElementById(riserId);
    const riserLabel = document.getElementById(riserId + '-label');
    
    if (checkbox.checked) {
        // If chorus is enabled, place riser off to the side for manual placement
        if (chorusEnabled) {
            // Place brass risers in a grid off to the left side
            const riserNumber = parseInt(riserId.match(/\d+/)[0]);
            const row = Math.floor((riserNumber - 1) / 2); // 2 risers per row
            const col = (riserNumber - 1) % 2;
            brassRiserPositions[riserId] = { 
                x: 100 + (col * 140), // 140px spacing horizontally
                y: 200 + (row * 80)   // 80px spacing vertically
            };
            updateBrassRiserPosition(riserId);
        }
        riser.style.display = 'block';
        riserLabel.style.display = 'block';
    } else {
        riser.style.display = 'none';
        riserLabel.style.display = 'none';
    }
}

function toggleStageExtension(extensionId) {
    const checkbox = document.getElementById(extensionId + '-checkbox');
    const extensionSection = document.getElementById(extensionId + '-section');
    
    if (checkbox.checked) {
        extensionSection.style.display = 'block';
    } else {
        extensionSection.style.display = 'none';
    }
}

// Update player orientation to face the podium
// For ellipses, rotate so the long axis points toward the podium center
function updatePlayerOrientation(player, playerX, playerY) {
    // Only rotate ellipses (not circles)
    if (!player || player.tagName !== 'ellipse') return;
    
    // Calculate angle from player to podium
    const dx = podiumPosition.x - playerX;
    const dy = podiumPosition.y - playerY;
    const angleRad = Math.atan2(dy, dx);
    const angleDeg = angleRad * 180 / Math.PI;
    
    // Apply rotation transform around the ellipse's center
    // Add 90 degrees because ellipse's major axis is vertical by default (ry > rx)
    // and we want it to point toward the podium
    const rotationAngle = angleDeg + 90;
    player.setAttribute('transform', `rotate(${rotationAngle} ${playerX} ${playerY})`);
}

// Update orientation for all ellipse players
function updateAllPlayerOrientations() {
    const allPlayers = document.querySelectorAll('.stage-plot ellipse[data-player-id]');
    allPlayers.forEach(player => {
        const cx = parseFloat(player.getAttribute('cx'));
        const cy = parseFloat(player.getAttribute('cy'));
        updatePlayerOrientation(player, cx, cy);
    });
}

function createPlayer(section, className, playerId, pos, label, instrumentType) {
    // Calculate dynamic radius based on square footage
    const radius = calculatePlayerRadius(instrumentType);
    const playerWidth = radius * 2;
    
    // Store original position for debugging
    const originalPos = { x: pos.x, y: pos.y };
    originalPositions[playerId] = originalPos;
    
    // Check if there's a custom position for this player
    const customPos = customPositions[playerId];
    const finalPos = customPos || originalPos;
    
    // Determine if this should be an oval or circle
    // Cellos and basses stay as circles; all others become ovals (6:7 width:height ratio)
    const useCircle = (instrumentType === 'cello' || instrumentType === 'bass');
    
    let player;
    if (useCircle) {
        // Create player circle for cello and bass
        player = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        player.setAttribute('cx', finalPos.x);
        player.setAttribute('cy', finalPos.y);
        player.setAttribute('r', radius);
    } else {
        // Create player ellipse for all other instruments (6:7 width:height ratio)
        // Maintain same area: π × rx × ry = π × r²
        // With rx/ry = 6/7: rx = r × √(6/7), ry = r × √(7/6)
        const rx = radius * Math.sqrt(6/7);  // Horizontal radius (width)
        const ry = radius * Math.sqrt(7/6);  // Vertical radius (height)
        
        player = document.createElementNS('http://www.w3.org/2000/svg', 'ellipse');
        player.setAttribute('cx', finalPos.x);
        player.setAttribute('cy', finalPos.y);
        player.setAttribute('rx', rx);
        player.setAttribute('ry', ry);
        
        // Orient ellipse toward podium
        updatePlayerOrientation(player, finalPos.x, finalPos.y);
    }
    
    player.setAttribute('class', className);
    player.setAttribute('data-player-id', playerId);
    player.setAttribute('data-instrument-type', instrumentType);
    
    // Add position highlight for debugging
    const highlight = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    highlight.setAttribute('class', 'position-highlight');
    highlight.setAttribute('cx', originalPos.x);
    highlight.setAttribute('cy', originalPos.y);
    highlight.setAttribute('r', radius + 3);
    section.appendChild(highlight);
    
    // Create player label
    const playerLabel = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    playerLabel.setAttribute('class', 'player-label');
    playerLabel.setAttribute('x', finalPos.x);
    playerLabel.setAttribute('y', finalPos.y);
    playerLabel.textContent = label;
    
    // Make draggable
    makeDraggable(player, playerLabel, playerId);
    
    // Add click event for keyboard selection
    player.addEventListener('click', function(e) {
        if (!isDragging) {
            e.stopPropagation();
            selectObject(playerId, 'player');
        }
    });
    
    section.appendChild(player);
    section.appendChild(playerLabel);
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

// Stage Plot Functions
function updateStagePlot(skipPositionClearing = false) {
    // Save existing positions BEFORE clearing (for when "Use Default Seating" is OFF)
    // Skip this logic when restoring from saved state
    if (!skipPositionClearing) {
        if (!useDefaultSeating) {
            // Save violin 1 positions
            const v1Players = document.querySelectorAll('[data-player-id^="violin1-"]');
            v1Players.forEach(player => {
                const playerId = player.getAttribute('data-player-id');
                customPositions[playerId] = {
                    x: parseFloat(player.getAttribute('cx')),
                    y: parseFloat(player.getAttribute('cy'))
                };
            });
            
            // Save violin 2 positions
            const v2Players = document.querySelectorAll('[data-player-id^="violin2-"]');
            v2Players.forEach(player => {
                const playerId = player.getAttribute('data-player-id');
                customPositions[playerId] = {
                    x: parseFloat(player.getAttribute('cx')),
                    y: parseFloat(player.getAttribute('cy'))
                };
            });
        } else {
            // Clear saved positions when using default seating
            Object.keys(customPositions).forEach(key => {
                if (key.startsWith('violin1-') || key.startsWith('violin2-')) {
                    delete customPositions[key];
                }
            });
        }
    }
    
    // Clear existing players
    clearStagePlot();
    
    // Update string sections
    updateViolin1Section();
    updateViolin2Section();
    updateViolaSection();
    updateCelloSection();
    updateBassSection();
    
    // Update dynamic instruments
    updateDynamicInstruments();
    
    // Update all player orientations to face the podium
    updateAllPlayerOrientations();
}

function clearStagePlot() {
    const sections = ['violin1-section', 'violin2-section', 'viola-section', 'cello-section', 'bass-section', 'woodwinds-section', 'keyboard-section'];
    sections.forEach(sectionId => {
        const section = document.getElementById(sectionId);
        if (section) {
            section.innerHTML = '';
        }
    });
    
    // Clear percussion section but preserve the blob group
    const percussionSection = document.getElementById('percussion-section');
    if (percussionSection) {
        // Remove everything except the blob group
        const children = Array.from(percussionSection.children);
        children.forEach(child => {
            if (child.id !== 'percussion-blob-group') {
                child.remove();
            }
        });
    }
}

function updateViolin1Section() {
    const section = document.getElementById('violin1-section');
    const v1Count = parseInt(document.getElementById('violin1').value) || 0;
    const v2Count = parseInt(document.getElementById('violin2').value) || 0;
    const instrumentType = 'violin1';
    
    // Get positions based on whether default seating is enabled
    let positions;
    if (useDefaultSeating) {
        // Use template system (concert grand templates are used automatically if available)
        const violinPositions = getViolinPositions(v1Count, v2Count, concertGrandEnabled);
        positions = violinPositions.violin1;
    } else {
        // Use saved customPositions or default for new players
        positions = [];
        const maxY = 900; // Keep within viewBox height
        const startY = 150;
        const spacing = 30;
        const columnSpacing = 50;
        
        for (let i = 0; i < v1Count; i++) {
            const playerId = `violin1-${i + 1}`;
            if (customPositions[playerId]) {
                // Use saved position from customPositions
                positions.push(customPositions[playerId]);
            } else {
                // Place new players off to the side in a grid pattern to stay within viewer
                const column = Math.floor((i * spacing + startY) / maxY);
                const yPos = startY + ((i * spacing) % (maxY - startY));
                const xPos = 100 + (column * columnSpacing);
                positions.push({ x: xPos, y: yPos });
            }
        }
    }
    
    for (let i = 0; i < v1Count && i < positions.length; i++) {
        const pos = positions[i];
        const playerId = `violin1-${i + 1}`;
        const label = `V1-${i + 1}`;
        
        createPlayer(section, 'violin1-player', playerId, pos, label, instrumentType);
    }
}

