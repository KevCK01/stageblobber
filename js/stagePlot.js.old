        { x: 450, y: 100 },   // Position 7
        { x: 500, y: 120 },   // Position 8
        { x: 120, y: 140 },   // Position 9
        { x: 170, y: 160 },   // Position 10
        { x: 220, y: 180 },   // Position 11
        { x: 270, y: 160 },   // Position 12
        { x: 320, y: 180 },   // Position 13
        { x: 370, y: 160 },   // Position 14
        { x: 420, y: 180 },   // Position 15
        { x: 470, y: 160 },   // Position 16
        { x: 100, y: 200 },   // Position 17
        { x: 150, y: 220 },   // Position 18
        { x: 200, y: 240 },   // Position 19
        { x: 250, y: 220 },   // Position 20
    ];
    
    let positionIndex = 0;
    
    // Get all percussion instruments
    const percussion = ['timpani', 'snare', 'xylophone', 'marimba', 'cymbals', 'vibraphone', 'glockenspiel', 'chimes', 'bassDrum', 'cymbal'];
    
    dynamicInstruments.forEach(instrumentId => {
        if (percussion.some(p => instrumentId.startsWith(p))) {
            const count = parseInt(document.getElementById(instrumentId).value) || 0;
            const instrumentName = instrumentId.split('_')[0]; // Get base instrument name
            
