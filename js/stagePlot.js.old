// Scale Constants for Real-World Measurements
const PIXELS_PER_FOOT = 15;                    // 15 pixels = 1 foot
const STAGE_DOWNSTAGE_WIDTH_FEET = 42;         // 42 feet wide downstage
const STAGE_UPSTAGE_WIDTH_FEET = 35;           // 35 feet wide upstage
const STAGE_DEPTH_FEET = 39;                   // 39 feet deep stage

// Podium dimensions and space calculation
const PODIUM_MAIN_SQFT = (50 * 50) / 144;      // 50" × 50" main podium = 17.36 sq ft
const PODIUM_STEP_SQFT = (27 * 13) / 144;      // 27" × 13" step = 2.44 sq ft
const PODIUM_TOTAL_SQFT = PODIUM_MAIN_SQFT + PODIUM_STEP_SQFT;  // 19.8 sq ft

const TOTAL_STAGE_SPACE = ((STAGE_DOWNSTAGE_WIDTH_FEET + STAGE_UPSTAGE_WIDTH_FEET) * STAGE_DEPTH_FEET / 2) - PODIUM_TOTAL_SQFT;  // 1501.5 - 19.8 = 1481.7 sq ft

// Utility functions for scale conversion
function feetToPixels(feet) {
    return feet * PIXELS_PER_FOOT;
}

function pixelsToFeet(pixels) {
    return pixels / PIXELS_PER_FOOT;
}

function sqftToRadius(sqft) {
    // Calculate radius based on actual square footage
    // Area = π × r²  →  r = √(area / π)
    const areaInPixels = sqft * PIXELS_PER_FOOT * PIXELS_PER_FOOT;
    const radius = Math.sqrt(areaInPixels / Math.PI);
    
    // Clamp radius for visibility (minimum 6px, maximum 120px for 100 sq ft)
    return Math.max(6, Math.min(120, radius));
}

// Dynamic circle sizing based on square footage
function calculatePlayerRadius(instrumentType) {
    const sqftElement = document.getElementById(instrumentType + '_sqft');
    if (!sqftElement) return 12; // Default radius if not found
    
    const sqft = parseFloat(sqftElement.value) || 8;
    return sqftToRadius(sqft);
}

// Instrument management
const staticInstruments = ['violin1', 'violin2', 'viola', 'cello', 'bass', 'flute', 'oboe', 'clarinet', 'bassoon'];
let dynamicInstruments = [];
let nextInstrumentId = 1;

// Drag and Drop Variables
let isDragging = false;
let draggedElement = null;
let draggedLabel = null;
let dragOffset = { x: 0, y: 0 };
let customPositions = {};
let originalPositions = {};
let debugMode = false;
let collisionDetectionEnabled = true;
let useDefaultSeating = true;

// Multi-select Variables
let selectedPlayers = new Set();
let selectedRisers = new Set();
let isSelecting = false;
let selectionStart = { x: 0, y: 0 };
let selectionRect = null;
let isGroupDragging = false;
let isGroupDraggingRisers = false;
let groupDragOffsets = new Map();
let groupDragLabels = new Map();
let groupRiserDragOffsets = new Map();

// Keyboard navigation variables
let selectedObject = null;
let selectedObjectType = null; // 'player', 'podium', 'timpani-riser', 'brass-riser'

// Snap-to functionality for risers
const SNAP_DISTANCE = 15; // pixels - distance within which risers will snap (15px = 1 foot)
const SNAP_TOLERANCE = 15; // pixels - how close alignment needs to be

// Riser selection functions
function selectRiser(riserId) {
    selectedRisers.add(riserId);
    const riser = document.getElementById(riserId);
    if (riser) {
        riser.classList.add('selected');
    }
}

function deselectRiser(riserId) {
    selectedRisers.delete(riserId);
    const riser = document.getElementById(riserId);
    if (riser) {
        riser.classList.remove('selected');
    }
}

function clearRiserSelection() {
    selectedRisers.forEach(riserId => {
        const riser = document.getElementById(riserId);
        if (riser) {
            riser.classList.remove('selected');
        }
    });
    selectedRisers.clear();
}

function toggleRiserSelection(riserId) {
    if (selectedRisers.has(riserId)) {
        deselectRiser(riserId);
    } else {
        selectRiser(riserId);
    }
}

// Get all visible risers with their positions and dimensions
function getAllVisibleRisers() {
    const risers = [];
    
    // Timpani riser
    const timpaniRiser = document.getElementById('timpani-riser');
    if (timpaniRiser && timpaniRiser.style.display !== 'none') {
        risers.push({
            id: 'timpani-riser',
            type: 'timpani',
            x: parseFloat(timpaniRiser.getAttribute('x')),
            y: parseFloat(timpaniRiser.getAttribute('y')),
            width: parseFloat(timpaniRiser.getAttribute('width')),
            height: parseFloat(timpaniRiser.getAttribute('height'))
        });
    }
    
    // Brass risers
    for (let i = 1; i <= 5; i++) {
        const brassRiser = document.getElementById(`brass-riser-${i}`);
        if (brassRiser && brassRiser.style.display !== 'none') {
            risers.push({
                id: `brass-riser-${i}`,
                type: 'brass',
                x: parseFloat(brassRiser.getAttribute('x')),
                y: parseFloat(brassRiser.getAttribute('y')),
                width: parseFloat(brassRiser.getAttribute('width')),
                height: parseFloat(brassRiser.getAttribute('height'))
            });
        }
    }
    
    // Woodwind risers
    for (let i = 1; i <= 4; i++) {
        const woodwindRiser = document.getElementById(`woodwind-riser-${i}`);
        if (woodwindRiser && woodwindRiser.style.display !== 'none') {
            risers.push({
                id: `woodwind-riser-${i}`,
                type: 'woodwind',
                x: parseFloat(woodwindRiser.getAttribute('x')),
                y: parseFloat(woodwindRiser.getAttribute('y')),
                width: parseFloat(woodwindRiser.getAttribute('width')),
                height: parseFloat(woodwindRiser.getAttribute('height'))
            });
        }
    }
    
    // Extra risers
    extraRisers.forEach(riserData => {
        risers.push({
            id: riserData.id,
            type: 'extra',
            x: riserData.x,
            y: riserData.y,
            width: riserData.config.width,
            height: riserData.config.height
        });
    });
    
    // Chorus risers
    chorusRisers.forEach(riserData => {
        risers.push({
            id: riserData.id,
            type: 'chorus',
            x: riserData.x,
            y: riserData.y,
            width: riserData.config.width,
            height: riserData.config.height
        });
    });
    
    return risers;
}

// Check if a riser should snap to nearby risers and return adjusted position
function getSnapPosition(currentRiserId, newX, newY, riserWidth, riserHeight) {
    const allRisers = getAllVisibleRisers();
    const otherRisers = allRisers.filter(r => r.id !== currentRiserId);
    
    let snapX = newX;
    let snapY = newY;
    
    // SNAP TO STAGE CENTER LINE
    const stageCenterX = 500; // Stage width is 1000, so center is at 500
    const riserCenterX = snapX + riserWidth / 2;
    
    // Check if riser center is close to stage center
    if (Math.abs(riserCenterX - stageCenterX) < SNAP_DISTANCE) {
        // Snap riser so its center aligns with stage center
        snapX = stageCenterX - riserWidth / 2;
    }
    
    for (const otherRiser of otherRisers) {
        // Calculate current riser edges and center
        const currentLeft = snapX;
        const currentRight = snapX + riserWidth;
        const currentTop = snapY;
        const currentBottom = snapY + riserHeight;
        const currentCenterX = snapX + riserWidth / 2;
        const currentCenterY = snapY + riserHeight / 2;
        
        // Calculate other riser edges and center
        const otherLeft = otherRiser.x;
        const otherRight = otherRiser.x + otherRiser.width;
        const otherTop = otherRiser.y;
        const otherBottom = otherRiser.y + otherRiser.height;
        const otherCenterX = otherRiser.x + otherRiser.width / 2;
        const otherCenterY = otherRiser.y + otherRiser.height / 2;
        
        // HORIZONTAL PROXIMITY SNAPPING (no Y alignment required)
        // Check if riser is close horizontally and snap, regardless of Y position
        // This allows snapping to risers side-by-side even when not perfectly aligned vertically
        const originalLeft = newX;
        const originalRight = newX + riserWidth;
        if (Math.abs(originalRight - otherLeft) < SNAP_DISTANCE) {
            // Current riser is to the left of other riser - snap right edge to other's left edge
            snapX = otherLeft - riserWidth;
        }
        else if (Math.abs(originalLeft - otherRight) < SNAP_DISTANCE) {
            // Current riser is to the right of other riser - snap left edge to other's right edge
            snapX = otherRight;
        }
        
        // HORIZONTAL EDGE SNAPPING (Y-axis alignment)
        // Check if horizontally aligned (same Y position) - for side-by-side placement
        // Use original newY for Y comparison to avoid interference from other snap logic
        if (Math.abs(newY - otherRiser.y) < SNAP_TOLERANCE) {
            // Use original newX for edge distance checks to ensure snapping works even if already snapped to center
            // Snap to left side of other riser (current riser goes to the left)
            if (Math.abs(originalRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
            }
            // Snap to right side of other riser (current riser goes to the right)
            else if (Math.abs(originalLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
            }
        }
        
        // BRICK PATTERN SNAPPING - Horizontal offset by half width
        // Check if vertically offset by half riser height (brick pattern)
        const halfHeightOffset = Math.abs((snapY + riserHeight / 2) - (otherRiser.y + otherRiser.height / 2));
        if (halfHeightOffset < SNAP_TOLERANCE) {
            // Snap to left side with brick pattern
            if (Math.abs(currentRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
                snapY = otherRiser.y; // Align to same Y for brick pattern
            }
            // Snap to right side with brick pattern
            else if (Math.abs(currentLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
                snapY = otherRiser.y; // Align to same Y for brick pattern
            }
        }
        
        // BRICK PATTERN SNAPPING - Vertical offset by half height
        // Check if horizontally offset by half riser width (vertical brick pattern)
        const halfWidthOffsetCheck = Math.abs((snapX + riserWidth / 2) - (otherRiser.x + otherRiser.width / 2));
        if (halfWidthOffsetCheck < SNAP_TOLERANCE) {
            // Snap to top with vertical brick pattern
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
                snapX = otherRiser.x; // Align to same X for vertical brick pattern
            }
            // Snap to bottom with vertical brick pattern
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
                snapX = otherRiser.x; // Align to same X for vertical brick pattern
            }
        }
        
        // CENTER-TO-CENTER SNAPPING (Horizontal brick pattern offset)
        // Check if centers are offset by half riser width horizontally
        const halfWidthOffset = riserWidth / 2;
        if (Math.abs(currentCenterX - (otherCenterX + halfWidthOffset)) < SNAP_TOLERANCE ||
            Math.abs(currentCenterX - (otherCenterX - halfWidthOffset)) < SNAP_TOLERANCE) {
            
            // Snap for side-by-side brick pattern
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
                // Position for brick offset
                if (Math.abs(currentCenterX - (otherCenterX + halfWidthOffset)) < SNAP_TOLERANCE) {
                    snapX = otherCenterX + halfWidthOffset - riserWidth / 2;
                } else {
                    snapX = otherCenterX - halfWidthOffset - riserWidth / 2;
                }
            }
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
                // Position for brick offset
                if (Math.abs(currentCenterX - (otherCenterX + halfWidthOffset)) < SNAP_TOLERANCE) {
                    snapX = otherCenterX + halfWidthOffset - riserWidth / 2;
                } else {
                    snapX = otherCenterX - halfWidthOffset - riserWidth / 2;
                }
            }
        }
        
        // CENTER-TO-CENTER SNAPPING (Vertical brick pattern offset)
        // Check if centers are offset by half riser height vertically
        const halfHeightOffsetSnap = riserHeight / 2;
        if (Math.abs(currentCenterY - (otherCenterY + halfHeightOffsetSnap)) < SNAP_TOLERANCE ||
            Math.abs(currentCenterY - (otherCenterY - halfHeightOffsetSnap)) < SNAP_TOLERANCE) {
            
            // Snap for stacked brick pattern
            if (Math.abs(currentRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
                // Position for vertical brick offset
                if (Math.abs(currentCenterY - (otherCenterY + halfHeightOffsetSnap)) < SNAP_TOLERANCE) {
                    snapY = otherCenterY + halfHeightOffsetSnap - riserHeight / 2;
                } else {
                    snapY = otherCenterY - halfHeightOffsetSnap - riserHeight / 2;
                }
            }
            else if (Math.abs(currentLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
                // Position for vertical brick offset
                if (Math.abs(currentCenterY - (otherCenterY + halfHeightOffsetSnap)) < SNAP_TOLERANCE) {
                    snapY = otherCenterY + halfHeightOffsetSnap - riserHeight / 2;
                } else {
                    snapY = otherCenterY - halfHeightOffsetSnap - riserHeight / 2;
                }
            }
        }
        
        // Check for bottom edge alignment (current bottom aligns with other bottom)
        if (Math.abs(currentBottom - otherBottom) < SNAP_TOLERANCE) {
            snapY = otherBottom - riserHeight;
            // Also check for side-by-side snapping when bottom edges are aligned
            if (Math.abs(currentRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
            }
            else if (Math.abs(currentLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
            }
        }
        
        // Check for top edge alignment (current top aligns with other top)
        if (Math.abs(currentTop - otherTop) < SNAP_TOLERANCE) {
            snapY = otherTop;
            // Also check for side-by-side snapping when top edges are aligned
            if (Math.abs(currentRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
            }
            else if (Math.abs(currentLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
            }
        }
        
        // VERTICAL PROXIMITY SNAPPING (no X alignment required)
        // Check if riser is close vertically and snap, regardless of X position
        // This allows snapping to risers above/below even when not horizontally aligned
        // Use original newY for comparison to avoid interference from other snap logic
        const originalTop = newY;
        const originalBottom = newY + riserHeight;
        if (Math.abs(originalTop - otherBottom) < SNAP_DISTANCE) {
            // Current riser is below other riser - snap top to other's bottom
            snapY = otherBottom;
        }
        else if (Math.abs(originalBottom - otherTop) < SNAP_DISTANCE) {
            // Current riser is above other riser - snap bottom to other's top
            snapY = otherTop - riserHeight;
        }
        
        // VERTICAL EDGE SNAPPING (X-axis alignment)
        // Check if vertically aligned (same X position) - for stacked placement
        if (Math.abs(snapX - otherRiser.x) < SNAP_TOLERANCE) {
            // Snap to top of other riser (current riser goes above)
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
            }
            // Snap to bottom of other riser (current riser goes below)
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
            }
        }
        
        // Check for left edge alignment (current left aligns with other left)
        if (Math.abs(currentLeft - otherLeft) < SNAP_TOLERANCE) {
            snapX = otherLeft;
            // Also check for stacked snapping when left edges are aligned
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
            }
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
            }
        }
        
        // Check for right edge alignment (current right aligns with other right)
        if (Math.abs(currentRight - otherRight) < SNAP_TOLERANCE) {
            snapX = otherRight - riserWidth;
            // Also check for stacked snapping when right edges are aligned
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
            }
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
            }
        }
        
        // CENTER-TO-EDGE SNAPPING (Additional brick pattern support)
        // Snap center of current riser to edges of other riser (horizontal)
        if (Math.abs(currentCenterX - otherLeft) < SNAP_TOLERANCE) {
            snapX = otherLeft - riserWidth / 2;
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
            }
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
            }
        }
        else if (Math.abs(currentCenterX - otherRight) < SNAP_TOLERANCE) {
            snapX = otherRight - riserWidth / 2;
            if (Math.abs(currentBottom - otherTop) < SNAP_DISTANCE) {
                snapY = otherTop - riserHeight;
            }
            else if (Math.abs(currentTop - otherBottom) < SNAP_DISTANCE) {
                snapY = otherBottom;
            }
        }
        
        // CENTER-TO-EDGE SNAPPING (Vertical brick pattern support)
        // Snap center of current riser to edges of other riser (vertical)
        if (Math.abs(currentCenterY - otherTop) < SNAP_TOLERANCE) {
            snapY = otherTop - riserHeight / 2;
            if (Math.abs(currentRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
            }
            else if (Math.abs(currentLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
            }
        }
        else if (Math.abs(currentCenterY - otherBottom) < SNAP_TOLERANCE) {
            snapY = otherBottom - riserHeight / 2;
            if (Math.abs(currentRight - otherLeft) < SNAP_DISTANCE) {
                snapX = otherLeft - riserWidth;
            }
            else if (Math.abs(currentLeft - otherRight) < SNAP_DISTANCE) {
                snapX = otherRight;
            }
        }
        
        // CORNER-TO-CORNER AND EDGE-TO-EDGE SNAPPING
        // When risers are close in both dimensions, check for various alignments
        const distanceX = Math.min(
            Math.abs(currentLeft - otherLeft),
            Math.abs(currentLeft - otherRight),
            Math.abs(currentRight - otherLeft),
            Math.abs(currentRight - otherRight)
        );
        const distanceY = Math.min(
            Math.abs(currentTop - otherTop),
            Math.abs(currentTop - otherBottom),
            Math.abs(currentBottom - otherTop),
            Math.abs(currentBottom - otherBottom)
        );
        
        if (distanceX < SNAP_DISTANCE && distanceY < SNAP_DISTANCE) {
            // Snap left edges together
            if (Math.abs(currentLeft - otherLeft) < SNAP_TOLERANCE) {
                snapX = otherLeft;
            }
            // Snap right edges together
            else if (Math.abs(currentRight - otherRight) < SNAP_TOLERANCE) {
                snapX = otherRight - riserWidth;
            }
            // Snap current left to other right
            else if (Math.abs(currentLeft - otherRight) < SNAP_TOLERANCE) {
                snapX = otherRight;
            }
            // Snap current right to other left
            else if (Math.abs(currentRight - otherLeft) < SNAP_TOLERANCE) {
                snapX = otherLeft - riserWidth;
            }
            
            // Snap top edges together
            if (Math.abs(currentTop - otherTop) < SNAP_TOLERANCE) {
                snapY = otherTop;
            }
            // Snap bottom edges together
            else if (Math.abs(currentBottom - otherBottom) < SNAP_TOLERANCE) {
                snapY = otherBottom - riserHeight;
            }
            // Snap current top to other bottom
            else if (Math.abs(currentTop - otherBottom) < SNAP_TOLERANCE) {
                snapY = otherBottom;
            }
            // Snap current bottom to other top
            else if (Math.abs(currentBottom - otherTop) < SNAP_TOLERANCE) {
                snapY = otherTop - riserHeight;
            }
        }
    }
    
    return { x: snapX, y: snapY };
}

function getAllInstruments() {
    return [...staticInstruments, ...dynamicInstruments];
}

function startEditing(instrumentId) {
    const display = document.querySelector(`.sq-ft-display[data-instrument="${instrumentId}"]`);
    const input = document.getElementById(instrumentId + '_sqft');
    
    if (display && input) {
        display.classList.add('editing');
        input.classList.add('editing');
        input.focus();
        input.select();
    }
}

function stopEditing(instrumentId) {
    const display = document.querySelector(`.sq-ft-display[data-instrument="${instrumentId}"]`);
    const input = document.getElementById(instrumentId + '_sqft');
    
    if (display && input) {
        display.classList.remove('editing');
        input.classList.remove('editing');
        
        // Update display text
        const value = parseFloat(input.value) || 8;
        display.textContent = `${value} sq ft each`;
        
        // Recalculate space
        calculateSpace();
    }
}

function updateSqFtDisplay(instrumentId) {
    const display = document.querySelector(`.sq-ft-display[data-instrument="${instrumentId}"]`);
    const input = document.getElementById(instrumentId + '_sqft');
    
    if (display && input) {
        const value = parseFloat(input.value) || 8;
        display.textContent = `${value} sq ft each`;
    }
}

function makeDraggable(player, label, playerId) {
    player.addEventListener('mousedown', function(e) {
        // Handle Ctrl/Cmd/Shift click for multi-select
        if (e.ctrlKey || e.metaKey || e.shiftKey) {
            togglePlayerSelection(playerId, player);
            e.preventDefault();
            return;
        }
        
        // If this player is not selected, clear selection and select only this player
        if (!selectedPlayers.has(playerId)) {
            clearSelection();
            addToSelection(playerId, player);
        }
        
        startDrag(e, player, label, playerId);
    });

    player.addEventListener('touchstart', function(e) {
        e.preventDefault();
        
        // If this player is not selected, clear selection and select only this player
        if (!selectedPlayers.has(playerId)) {
            clearSelection();
            addToSelection(playerId, player);
        }
        
        startDrag(e.touches[0], player, label, playerId);
    });
}

function startDrag(e, player, label, playerId) {
    isDragging = true;
    draggedElement = player;
    draggedLabel = label;

    // Check if we're dragging multiple players
    isGroupDragging = selectedPlayers.size > 1;
    
    // Add dragging class for visual feedback
    if (isGroupDragging) {
        selectedPlayers.forEach(id => {
            const p = document.querySelector(`[data-player-id="${id}"]`);
            if (p) p.classList.add('dragging');
        });
    } else {
        player.classList.add('dragging');
    }

    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    // Calculate scaling factors
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    // Calculate mouse position in SVG coordinates
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    // Calculate offset from center of circle/ellipse
    const cx = parseFloat(player.getAttribute('cx'));
    const cy = parseFloat(player.getAttribute('cy'));
    
    dragOffset = {
        x: mouseX - cx,
        y: mouseY - cy
    };

    // If group dragging, calculate offsets and store label references for all selected players
    if (isGroupDragging) {
        groupDragOffsets.clear();
        groupDragLabels.clear();
        selectedPlayers.forEach(id => {
            const p = document.querySelector(`[data-player-id="${id}"]`);
            if (p) {
                const pcx = parseFloat(p.getAttribute('cx'));
                const pcy = parseFloat(p.getAttribute('cy'));
                groupDragOffsets.set(id, {
                    x: mouseX - pcx,
                    y: mouseY - pcy
                });
                
                // Find and store the corresponding label
                const labels = document.querySelectorAll('text.player-label');
                for (let label of labels) {
                    const labelX = parseFloat(label.getAttribute('x'));
                    const labelY = parseFloat(label.getAttribute('y'));
                    // Check if label is at the same position as the player (within 1 pixel tolerance)
                    if (Math.abs(labelX - pcx) < 1 && Math.abs(labelY - pcy) < 1) {
                        groupDragLabels.set(id, label);
                        break;
                    }
                }
            }
        });
    }

    // Add global event listeners
    document.addEventListener('mousemove', handleDragMove);
    document.addEventListener('mouseup', handleDragEnd);
    document.addEventListener('touchmove', handleDragMove);
    document.addEventListener('touchend', handleDragEnd);
}

// Function to check if a point is inside the trapezoidal stage
function isInsideStage(x, y, padding = 15) {
    // Trapezoid points: (237.5,80), (762.5,80), (815,665), (185,665)
    // Upstage narrow (35'), Downstage wide (42')
    // Add padding to create inner boundary
    const topLeft = { x: 237.5 + padding, y: 80 + padding };      // Upstage left
    const topRight = { x: 762.5 - padding, y: 80 + padding };     // Upstage right
    const bottomLeft = { x: 185 + padding, y: 665 - padding };    // Downstage left
    const bottomRight = { x: 815 - padding, y: 665 - padding };   // Downstage right
    
    // Check if point is within Y bounds
    if (y < topLeft.y || y > bottomLeft.y) return false;
    
    // Calculate the left and right boundaries at the given Y position
    // Linear interpolation between top and bottom points
    const yRatio = (y - topLeft.y) / (bottomLeft.y - topLeft.y);
    const leftBoundary = topLeft.x + yRatio * (bottomLeft.x - topLeft.x);
    const rightBoundary = topRight.x + yRatio * (bottomRight.x - topRight.x);
    
    // Check if point is within X bounds at this Y level
    return x >= leftBoundary && x <= rightBoundary;
}

// Function to check if two circles overlap
function circlesOverlap(x1, y1, r1, x2, y2, r2, minSpacing = 0.5) {
    // Calculate distance between centers
    const dx = x2 - x1;
    const dy = y2 - y1;
    const distance = Math.sqrt(dx * dx + dy * dy);
    
    // Circles overlap if distance is less than sum of radii plus minimum spacing
    // minSpacing of 0.5px allows players to get very close without overlapping
    return distance < (r1 + r2 + minSpacing);
}

// Function to check if a position would cause collision with other players
// Helper function to get rotation angle from transform attribute
function getRotationAngle(element) {
    const transform = element.getAttribute('transform');
    if (!transform) return 0;
    
    const match = transform.match(/rotate\(([-\d.]+)/);
    return match ? parseFloat(match[1]) * Math.PI / 180 : 0; // Convert to radians
}

// Helper function to calculate effective radius of an ellipse at a given angle
function getEllipseRadiusAtAngle(rx, ry, angle) {
    // Formula: r(θ) = (a*b) / sqrt((b*cos(θ))^2 + (a*sin(θ))^2)
    const cosA = Math.cos(angle);
    const sinA = Math.sin(angle);
    return (rx * ry) / Math.sqrt((ry * cosA) ** 2 + (rx * sinA) ** 2);
}

// Check if two ellipses/circles collide (accounting for rotation)
function playersOverlap(player1, x1, y1, player2, x2, y2) {
    // Calculate distance between centers
    const dx = x2 - x1;
    const dy = y2 - y1;
    const distance = Math.sqrt(dx * dx + dy * dy);
    
    // If distance is 0, they're overlapping
    if (distance === 0) return true;
    
    // Calculate angle from player1 to player2
    const angleBetween = Math.atan2(dy, dx);
    
    // Get radius of player1 in direction of player2
    let radius1;
    if (player1.tagName === 'ellipse') {
        const rx1 = parseFloat(player1.getAttribute('rx'));
        const ry1 = parseFloat(player1.getAttribute('ry'));
        const rotation1 = getRotationAngle(player1);
        // Adjust angle relative to player1's rotation
        const relativeAngle1 = angleBetween - rotation1;
        radius1 = getEllipseRadiusAtAngle(rx1, ry1, relativeAngle1);
    } else {
        radius1 = parseFloat(player1.getAttribute('r'));
    }
    
    // Get radius of player2 in direction of player1 (opposite direction)
    let radius2;
    if (player2.tagName === 'ellipse') {
        const rx2 = parseFloat(player2.getAttribute('rx'));
        const ry2 = parseFloat(player2.getAttribute('ry'));
        const rotation2 = getRotationAngle(player2);
        // Adjust angle relative to player2's rotation (opposite direction)
        const relativeAngle2 = (angleBetween + Math.PI) - rotation2;
        radius2 = getEllipseRadiusAtAngle(rx2, ry2, relativeAngle2);
    } else {
        radius2 = parseFloat(player2.getAttribute('r'));
    }
    
    // Check if distance is less than sum of radii
    return distance < (radius1 + radius2);
}

function wouldCollide(playerId, newX, newY, excludeIds = new Set()) {
    // Get all players (both circles and ellipses)
    const allPlayers = document.querySelectorAll('.stage-plot circle[data-player-id], .stage-plot ellipse[data-player-id]');
    
    // Get the player being moved
    const movingPlayer = document.querySelector(`[data-player-id="${playerId}"]`);
    if (!movingPlayer) return false;
    
    for (const player of allPlayers) {
        const otherId = player.getAttribute('data-player-id');
        
        // Skip self and excluded players
        if (otherId === playerId || excludeIds.has(otherId)) continue;
        
        const otherX = parseFloat(player.getAttribute('cx'));
        const otherY = parseFloat(player.getAttribute('cy'));
        
        // Use improved ellipse collision detection
        if (playersOverlap(movingPlayer, newX, newY, player, otherX, otherY)) {
            return true;
        }
    }
    
    // Check collision with percussion blob
    if (collisionDetectionEnabled && typeof circleCollidesWithBlob === 'function') {
        // For blob collision, use approximate bounding circle
        let movingRadius;
        if (movingPlayer.tagName === 'ellipse') {
            const rx = parseFloat(movingPlayer.getAttribute('rx'));
            const ry = parseFloat(movingPlayer.getAttribute('ry'));
            movingRadius = Math.max(rx, ry);
        } else {
            movingRadius = parseFloat(movingPlayer.getAttribute('r'));
        }
        
        if (circleCollidesWithBlob(newX, newY, movingRadius)) {
            return true;
        }
    }
    
    return false;
}

// Function to find the closest valid position along a movement path
function findClosestValidPosition(playerId, fromX, fromY, toX, toY, excludeIds = new Set()) {
    // If collision detection is disabled, allow any position
    if (!collisionDetectionEnabled) {
        return { x: toX, y: toY };
    }
    
    // If target position is valid, return it
    if (!wouldCollide(playerId, toX, toY, excludeIds)) {
        return { x: toX, y: toY };
    }
    
    // If starting position would collide, something is wrong - return start
    if (wouldCollide(playerId, fromX, fromY, excludeIds)) {
        return { x: fromX, y: fromY };
    }
    
    // Binary search to find the closest valid position along the path
    let validX = fromX;
    let validY = fromY;
    let low = 0;
    let high = 1;
    const iterations = 10; // Good balance between precision and performance
    
    for (let i = 0; i < iterations; i++) {
        const mid = (low + high) / 2;
        const testX = fromX + (toX - fromX) * mid;
        const testY = fromY + (toY - fromY) * mid;
        
        if (wouldCollide(playerId, testX, testY, excludeIds)) {
            // Collision at this point, search earlier in path
            high = mid;
        } else {
            // Valid position, try to get closer
            validX = testX;
            validY = testY;
            low = mid;
        }
    }
    
    return { x: validX, y: validY };
}

function handleDragMove(e) {
    if (!isDragging || !draggedElement) return;

    e.preventDefault();
    
    // Get mouse/touch position
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    // Calculate scaling factors
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    // Calculate new position in SVG coordinates
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    if (isGroupDragging) {
        // For group dragging, maintain relative positions by calculating a common movement delta
        const newPositions = new Map();
        const currentPositions = new Map();
        const targetPositions = new Map();
        
        // Calculate current and target positions for all players
        selectedPlayers.forEach(id => {
            const player = document.querySelector(`[data-player-id="${id}"]`);
            const offset = groupDragOffsets.get(id);
            
            if (player && offset) {
                const currentX = parseFloat(player.getAttribute('cx'));
                const currentY = parseFloat(player.getAttribute('cy'));
                currentPositions.set(id, { x: currentX, y: currentY });
                
                let targetX = mouseX - offset.x;
                let targetY = mouseY - offset.y;
                
                // Constrain to canvas boundaries
                const canvasBounds = {
                    left: 0,
                    right: 1000,
                    top: 0,
                    bottom: 940
                };
                
                targetX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, targetX));
                targetY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, targetY));
                
                targetPositions.set(id, { x: targetX, y: targetY });
            }
        });
        
        // If collision detection is enabled, check if the entire group can move
        let groupCanMove = true;
        if (collisionDetectionEnabled) {
            // Check if any player in the group would collide at their target position
            for (const id of selectedPlayers) {
                const targetPos = targetPositions.get(id);
                if (targetPos && wouldCollide(id, targetPos.x, targetPos.y, selectedPlayers)) {
                    groupCanMove = false;
                    break;
                }
            }
        }
        
        // Update positions: use target if no collision, otherwise keep current
        selectedPlayers.forEach(id => {
            const player = document.querySelector(`[data-player-id="${id}"]`);
            const currentPos = currentPositions.get(id);
            const targetPos = targetPositions.get(id);
            
            if (player && currentPos && targetPos) {
                let finalPos;
                if (groupCanMove || !collisionDetectionEnabled) {
                    finalPos = targetPos;
                } else {
                    // Keep current position if group cannot move
                    finalPos = currentPos;
                }
                
                player.setAttribute('cx', finalPos.x);
                player.setAttribute('cy', finalPos.y);
                
                // Update orientation toward podium (for ellipses)
                updatePlayerOrientation(player, finalPos.x, finalPos.y);
                
                // Update the corresponding label
                const playerLabel = groupDragLabels.get(id);
                if (playerLabel) {
                    playerLabel.setAttribute('x', finalPos.x);
                    playerLabel.setAttribute('y', finalPos.y);
                }
            }
        });
    } else {
        // Single player drag
        let newX = mouseX - dragOffset.x;
        let newY = mouseY - dragOffset.y;
        
        // Constrain to canvas boundaries
        const canvasBounds = {
            left: 0,
            right: 1000,
            top: 0,
            bottom: 940
        };
        
        newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
        newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
        
        // Get current position
        const currentX = parseFloat(draggedElement.getAttribute('cx'));
        const currentY = parseFloat(draggedElement.getAttribute('cy'));
        
        // Find closest valid position along the drag path
        const playerId = draggedElement.getAttribute('data-player-id');
        const validPos = findClosestValidPosition(playerId, currentX, currentY, newX, newY, new Set());
        
        // Update to the closest valid position
        draggedElement.setAttribute('cx', validPos.x);
        draggedElement.setAttribute('cy', validPos.y);
        
        // Update orientation toward podium (for ellipses)
        updatePlayerOrientation(draggedElement, validPos.x, validPos.y);
        
        if (draggedLabel) {
            draggedLabel.setAttribute('x', validPos.x);
            draggedLabel.setAttribute('y', validPos.y);
        }
    }
}

function handleDragEnd(e) {
    if (isDragging && draggedElement) {
        // Remove dragging class
        if (isGroupDragging) {
            selectedPlayers.forEach(id => {
                const p = document.querySelector(`[data-player-id="${id}"]`);
                if (p) p.classList.remove('dragging');
            });
        } else {
            draggedElement.classList.remove('dragging');
        }
        
        // Store custom positions
        if (isGroupDragging) {
            selectedPlayers.forEach(id => {
                const player = document.querySelector(`[data-player-id="${id}"]`);
                if (player) {
                    customPositions[id] = {
                        x: parseFloat(player.getAttribute('cx')),
                        y: parseFloat(player.getAttribute('cy'))
                    };
                }
            });
        } else {
            const playerId = draggedElement.getAttribute('data-player-id');
            if (playerId) {
                customPositions[playerId] = {
                    x: parseFloat(draggedElement.getAttribute('cx')),
                    y: parseFloat(draggedElement.getAttribute('cy'))
                };
            }
        }
        
        // Update debug info if in debug mode
        if (debugMode) {
            updateDebugInfo();
        }

        // Clean up
        isDragging = false;
        isGroupDragging = false;
        draggedElement = null;
        draggedLabel = null;
        dragOffset = { x: 0, y: 0 };
        groupDragOffsets.clear();
        groupDragLabels.clear();
    }

    // Remove global event listeners
    document.removeEventListener('mousemove', handleDragMove);
    document.removeEventListener('mouseup', handleDragEnd);
    document.removeEventListener('touchmove', handleDragMove);
    document.removeEventListener('touchend', handleDragEnd);
}

function resetPlayerPositions() {
    customPositions = {};
    originalPositions = {};
    clearSelection();
    resetPodiumPosition();
    resetTimpaniRiserPosition();
    resetBrassRiserPositions();
    resetWoodwindRiserPositions();
    updateStagePlot();
    if (debugMode) {
        updateDebugInfo();
    }
}

// Podium drag functionality
let podiumPosition = { x: 500, y: 633.75 }; // Center of podium (perfectly flush with downstage edge)
let podiumOriginalY = 633.75; // Store original Y position for concert grand toggle
let podiumDragging = false;
let podiumDragOffset = { x: 0, y: 0 };

// Concert Grand variables
let concertGrandEnabled = false;
let concertGrandPosition = { x: 500, y: 705 }; // Center position: 9' wide (135px) × 5' deep (75px)
let concertGrandDragging = false;
let concertGrandDragOffset = { x: 0, y: 0 };

// Chorus variables
let chorusEnabled = false;
let chorusRows = 1; // Number of chorus riser rows
let chorusRisers = []; // Array to hold chorus riser data
let chorusSingers = []; // Array to hold singer data
let chorusSingersPerRow = []; // Array to hold number of singers per row

function initializePodium() {
    const podiumMain = document.getElementById('podium-main');
    const podiumStep = document.getElementById('podium-step');
    const podiumLabel = document.getElementById('podium-label');

    // Make both parts draggable
    [podiumMain, podiumStep].forEach(element => {
        element.addEventListener('mousedown', startPodiumDrag);
        element.addEventListener('touchstart', function(e) {
            e.preventDefault();
            startPodiumDrag(e.touches[0]);
        });
        
        // Add click event for keyboard selection
        element.addEventListener('click', function(e) {
            if (!podiumDragging) {
                e.stopPropagation();
                selectObject('podium-main', 'podium');
            }
        });
    });
}

function startPodiumDrag(e) {
    podiumDragging = true;
    
    // Add dragging class to both parts
    document.getElementById('podium-main').classList.add('dragging');
    document.getElementById('podium-step').classList.add('dragging');

    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    // Calculate scaling factors
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    // Calculate mouse position in SVG coordinates
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    // Calculate offset from center of podium
    podiumDragOffset = {
        x: mouseX - podiumPosition.x,
        y: mouseY - podiumPosition.y
    };

    // Add global event listeners
    document.addEventListener('mousemove', handlePodiumDragMove);
    document.addEventListener('mouseup', handlePodiumDragEnd);
    document.addEventListener('touchmove', handlePodiumDragMove);
    document.addEventListener('touchend', handlePodiumDragEnd);
}

function handlePodiumDragMove(e) {
    if (!podiumDragging) return;

    e.preventDefault();
    
    // Get mouse/touch position
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    // Calculate scaling factors
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    // Calculate new position in SVG coordinates
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    let newX = mouseX - podiumDragOffset.x;
    let newY = mouseY - podiumDragOffset.y;
    
    // Allow unrestricted movement anywhere on canvas
    // Constrain only to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000,  // SVG viewBox width
        top: 0,
        bottom: 940   // SVG viewBox height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Update podium position
    podiumPosition = { x: newX, y: newY };
    updatePodiumPosition();
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function handlePodiumDragEnd(e) {
    if (podiumDragging) {
        // Remove dragging class
        document.getElementById('podium-main').classList.remove('dragging');
        document.getElementById('podium-step').classList.remove('dragging');
        
        podiumDragging = false;
        podiumDragOffset = { x: 0, y: 0 };
    }

    // Remove global event listeners
    document.removeEventListener('mousemove', handlePodiumDragMove);
    document.removeEventListener('mouseup', handlePodiumDragEnd);
    document.removeEventListener('touchmove', handlePodiumDragMove);
    document.removeEventListener('touchend', handlePodiumDragEnd);
}

function updatePodiumPosition() {
    const podiumMain = document.getElementById('podium-main');
    const podiumStep = document.getElementById('podium-step');
    const podiumLabel = document.getElementById('podium-label');
    
    // Update main square position (center it on podiumPosition)
    podiumMain.setAttribute('x', podiumPosition.x - 31.25); // Half of 62.5
    podiumMain.setAttribute('y', podiumPosition.y - 31.25);
    
    // Update step position (flush against left edge of main square - stage right, rotated)
    podiumStep.setAttribute('x', podiumPosition.x - 31.25 - 16.25); // Right edge of step touches left edge of main square
    podiumStep.setAttribute('y', podiumPosition.y - 16.875); // Centered vertically on the side of podium square
    
    // Update label position
    podiumLabel.setAttribute('x', podiumPosition.x);
    podiumLabel.setAttribute('y', podiumPosition.y + 5); // Slightly below center
}

function resetPodiumPosition() {
    // Position podium perfectly flush with downstage edge
    // Downstage edge is at y=665, podium height is 62.5, so center at y=665-31.25 = 633.75
    podiumPosition = { x: 500, y: 633.75 };
    podiumOriginalY = 633.75;
    updatePodiumPosition();
}

// Concert Grand Piano functionality
// ============================================================================
// CONCERT GRAND PIANO SYSTEM
// ============================================================================
// When the concert grand checkbox is toggled:
//
// IF "Use Default Seating" is ENABLED:
//   - Regenerates entire stage plot using appropriate templates
//   - Checks for specialized "piano out" templates first (in violinPositions.js)
//   - If no specialized template exists, uses regular template shifted 3 feet upstage
//   - This ensures players are positioned optimally for the piano
//
// IF "Use Default Seating" is DISABLED:
//   - Simply shifts all existing string players by 3 feet (45px)
//   - Preserves manual positioning while making room for piano
//
// TO ADD NEW "PIANO OUT" TEMPLATES:
//   - See detailed instructions in js/violinPositions.js
//   - Add templates to the concertGrandViolinTemplates object
// ============================================================================
function toggleConcertGrand() {
    const checkbox = document.getElementById('concert-grand-toggle');
    concertGrandEnabled = checkbox.checked;
    const concertGrandSection = document.getElementById('concert-grand-section');
    
    if (concertGrandEnabled) {
        // Show the concert grand
        concertGrandSection.style.display = 'block';
        
        // Move podium to specific position for concert grand soloist
        podiumPosition.x = 500.0;
        podiumPosition.y = 597.8;
        updatePodiumPosition();
        
        // Position concert grand downstage of podium
        concertGrandPosition = { x: 500, y: podiumOriginalY + 37.5 }; // 37.5px down from original podium
        updateConcertGrandPosition();
        
        // Initialize drag functionality if not already done
        if (!concertGrandSection.dataset.initialized) {
            initializeConcertGrand();
            concertGrandSection.dataset.initialized = 'true';
        }
    } else {
        // Hide the concert grand
        concertGrandSection.style.display = 'none';
        
        // Move podium back to original position
        podiumPosition.y = podiumOriginalY;
        updatePodiumPosition();
    }
    
    // If "Use Default Seating" is enabled, regenerate entire stage plot with appropriate templates
    if (useDefaultSeating) {
        // Full regeneration (will use concert grand templates if appropriate)
        updateStagePlot();
    } else {
        // Shift all existing string players manually
        const shiftY = concertGrandEnabled ? -45 : 45;
        const stringPlayerSelectors = [
            '[data-player-id^="violin1-"]',
            '[data-player-id^="violin2-"]',
            '[data-player-id^="viola-"]',
            '[data-player-id^="cello-"]',
            '[data-player-id^="bass-"]'
        ];
        
        stringPlayerSelectors.forEach(selector => {
            const players = document.querySelectorAll(selector);
            players.forEach(player => {
                const currentX = parseFloat(player.getAttribute('cx'));
                const currentY = parseFloat(player.getAttribute('cy'));
                const newY = currentY + shiftY;
                player.setAttribute('cy', newY);
                
                // Update orientation toward podium (for ellipses)
                updatePlayerOrientation(player, currentX, newY);
                
                // Find the associated label by matching x,y coordinates
                const labels = document.querySelectorAll('text.player-label');
                labels.forEach(label => {
                    const labelX = parseFloat(label.getAttribute('x'));
                    const labelY = parseFloat(label.getAttribute('y'));
                    // If label position matches player position (within 0.1px tolerance)
                    if (Math.abs(labelX - currentX) < 0.1 && Math.abs(labelY - currentY) < 0.1) {
                        label.setAttribute('y', labelY + shiftY);
                    }
                });
                
                // Update customPositions if exists
                const playerId = player.getAttribute('data-player-id');
                if (customPositions[playerId]) {
                    customPositions[playerId].y += shiftY;
                }
            });
        });
        
        // Update all player orientations after podium position change
        updateAllPlayerOrientations();
    }
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

// ===================================
// Chorus Functions
// ===================================

function toggleChorus() {
    const checkbox = document.getElementById('chorus-toggle');
    chorusEnabled = checkbox.checked;
    const chorusControls = document.getElementById('chorus-controls');
    
    if (chorusEnabled) {
        // Show chorus controls
        chorusControls.style.display = 'block';
        
        // Hide brass, woodwind, and timpani risers
        hideBrassWoodwindTimpaniRisers();
        
        // Create initial row of chorus risers
        chorusRows = 1;
        chorusSingersPerRow = [0]; // Initialize with 0 singers in first row
        createChorusRisers();
        updateChorusRowInputs();
        updateChorusRowCount();
    } else {
        // Hide chorus controls
        chorusControls.style.display = 'none';
        
        // Remove all chorus risers and singers
        clearChorusRisers();
        clearAllChorusSingers();
        chorusRows = 1; // Reset row count
        chorusSingersPerRow = [];
        
        // Show brass, woodwind, and timpani risers again
        showBrassWoodwindTimpaniRisers();
    }
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function hideBrassWoodwindTimpaniRisers() {
    // Hide and uncheck timpani riser
    const timpaniRiser = document.getElementById('timpani-riser');
    const timpaniLabel = document.getElementById('timpani-riser-label');
    const timpaniCheckbox = document.getElementById('timpani-riser-checkbox');
    if (timpaniRiser) timpaniRiser.style.display = 'none';
    if (timpaniLabel) timpaniLabel.style.display = 'none';
    if (timpaniCheckbox) timpaniCheckbox.checked = false;
    
    // Hide and uncheck brass risers
    for (let i = 1; i <= 5; i++) {
        const riser = document.getElementById(`brass-riser-${i}`);
        const label = document.getElementById(`brass-riser-${i}-label`);
        const checkbox = document.getElementById(`brass-riser-${i}-checkbox`);
        if (riser) riser.style.display = 'none';
        if (label) label.style.display = 'none';
        if (checkbox) checkbox.checked = false;
    }
    
    // Hide and uncheck woodwind risers
    for (let i = 1; i <= 4; i++) {
        const riser = document.getElementById(`woodwind-riser-${i}`);
        const label = document.getElementById(`woodwind-riser-${i}-label`);
        const checkbox = document.getElementById(`woodwind-riser-${i}-checkbox`);
        if (riser) riser.style.display = 'none';
        if (label) label.style.display = 'none';
        if (checkbox) checkbox.checked = false;
    }
}

function showBrassWoodwindTimpaniRisers() {
    // Check timpani checkbox state
    const timpaniCheckbox = document.getElementById('timpani-riser-checkbox');
    if (timpaniCheckbox && timpaniCheckbox.checked) {
        const timpaniRiser = document.getElementById('timpani-riser');
        const timpaniLabel = document.getElementById('timpani-riser-label');
        if (timpaniRiser) timpaniRiser.style.display = 'block';
        if (timpaniLabel) timpaniLabel.style.display = 'block';
    }
    
    // Check brass riser checkboxes
    for (let i = 1; i <= 5; i++) {
        const checkbox = document.getElementById(`brass-riser-${i}-checkbox`);
        if (checkbox && checkbox.checked) {
            const riser = document.getElementById(`brass-riser-${i}`);
            const label = document.getElementById(`brass-riser-${i}-label`);
            if (riser) riser.style.display = 'block';
            if (label) label.style.display = 'block';
        }
    }
    
    // Check woodwind riser checkboxes
    for (let i = 1; i <= 4; i++) {
        const checkbox = document.getElementById(`woodwind-riser-${i}-checkbox`);
        if (checkbox && checkbox.checked) {
            const riser = document.getElementById(`woodwind-riser-${i}`);
            const label = document.getElementById(`woodwind-riser-${i}-label`);
            if (riser) riser.style.display = 'block';
            if (label) label.style.display = 'block';
        }
    }
}

function createChorusRisers() {
    const svg = document.querySelector('#extra-risers-section');
    const config = riserConfigs['8x4']; // Use 8x4 risers for chorus
    const riserSpacing = 120; // 8 feet (120px) spacing horizontally
    const rowSpacing = 60; // 4 feet (60px) spacing vertically
    const baseY = 95; // Starting Y position for first row
    
    // Starting X positions for 4 risers per row
    const startingXPositions = [260, 380, 500, 620];
    
    // Create risers for each row
    for (let row = 0; row < chorusRows; row++) {
        const y = baseY + (row * rowSpacing);
        
        for (let i = 0; i < 4; i++) {
            const x = startingXPositions[i];
            const riserNumber = (row * 4) + (i + 1);
            const riserId = `chorus-riser-${riserNumber}`;
            
            const riserData = {
                id: riserId,
                size: '8x4',
                config: config,
                x: x,
                y: y,
                dragging: false,
                dragOffset: { x: 0, y: 0 },
                number: riserNumber
            };
            
            chorusRisers.push(riserData);
            createChorusRiserElements(riserData);
            initializeChorusRiser(riserId);
        }
    }
}

function createChorusRiserElements(riserData) {
    const svg = document.querySelector('#extra-risers-section');
    
    // Create riser rectangle
    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('id', riserData.id);
    rect.setAttribute('x', riserData.x);
    rect.setAttribute('y', riserData.y);
    rect.setAttribute('width', riserData.config.width);
    rect.setAttribute('height', riserData.config.height);
    rect.setAttribute('fill', '#9333ea'); // Purple color for chorus risers
    rect.setAttribute('stroke', '#7e22ce');
    rect.setAttribute('stroke-width', '2');
    rect.setAttribute('data-riser-type', 'chorus');
    rect.classList.add('riser-draggable');
    
    // Create label
    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('id', riserData.id + '-label');
    text.setAttribute('x', riserData.x + riserData.config.width / 2);
    text.setAttribute('y', riserData.y + riserData.config.height / 2 + 5);
    text.setAttribute('text-anchor', 'middle');
    text.setAttribute('fill', 'white');
    text.setAttribute('font-size', '10');
    text.setAttribute('font-weight', 'bold');
    text.classList.add('riser-label');
    text.textContent = `CHORUS #${riserData.number}`;
    
    svg.appendChild(rect);
    svg.appendChild(text);
}

function initializeChorusRiser(riserId) {
    const riser = document.getElementById(riserId);
    if (!riser) return;
    
    // Use the same drag functionality as extra risers
    riser.addEventListener('mousedown', function(e) {
        startChorusRiserDrag(e, riserId);
    });
    
    riser.addEventListener('touchstart', function(e) {
        e.preventDefault();
        startChorusRiserDrag(e.touches[0], riserId);
    });
    
    riser.addEventListener('click', function(e) {
        const riserData = chorusRisers.find(r => r.id === riserId);
        if (!riserData || !riserData.dragging) {
            e.stopPropagation();
            selectObject(riserId, riserId);
        }
    });
}

function startChorusRiserDrag(e, riserId) {
    // Handle multi-selection with Ctrl/Cmd/Shift key
    if (e.ctrlKey || e.metaKey || e.shiftKey) {
        toggleRiserSelection(riserId);
        return;
    }
    
    // If clicking on a non-selected riser, clear other selections
    if (!selectedRisers.has(riserId)) {
        clearRiserSelection();
        selectRiser(riserId);
    }
    
    const riserData = chorusRisers.find(r => r.id === riserId);
    if (!riserData) return;
    
    riserData.dragging = true;
    
    // Add dragging class
    document.getElementById(riserId).classList.add('dragging');
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    riserData.dragOffset = {
        x: mouseX - riserData.x,
        y: mouseY - riserData.y
    };
    
    // Add global event listeners
    document.addEventListener('mousemove', handleChorusRiserDragMove);
    document.addEventListener('mouseup', handleChorusRiserDragEnd);
    document.addEventListener('touchmove', handleChorusRiserDragMove);
    document.addEventListener('touchend', handleChorusRiserDragEnd);
}

function handleChorusRiserDragMove(e) {
    const draggingRiser = chorusRisers.find(r => r.dragging);
    if (!draggingRiser) return;
    
    e.preventDefault();
    
    // Get mouse/touch position
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    let newX = mouseX - draggingRiser.dragOffset.x;
    let newY = mouseY - draggingRiser.dragOffset.y;
    
    // Constrain to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000 - draggingRiser.config.width,
        top: 0,
        bottom: 940 - draggingRiser.config.height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Apply snap-to functionality
    const snapPosition = getSnapPosition(draggingRiser.id, newX, newY, draggingRiser.config.width, draggingRiser.config.height);
    newX = snapPosition.x;
    newY = snapPosition.y;
    
    // Calculate movement delta
    const deltaX = newX - draggingRiser.x;
    const deltaY = newY - draggingRiser.y;
    
    // Update riser position
    draggingRiser.x = newX;
    draggingRiser.y = newY;
    updateChorusRiserPosition(draggingRiser);
    
    // Move singers on this riser
    moveSingersWithRiser(draggingRiser.id, deltaX, deltaY);
}

function handleChorusRiserDragEnd(e) {
    const draggingRiser = chorusRisers.find(r => r.dragging);
    if (!draggingRiser) return;
    
    draggingRiser.dragging = false;
    
    // Remove dragging class
    document.getElementById(draggingRiser.id).classList.remove('dragging');
    
    // Remove global event listeners
    document.removeEventListener('mousemove', handleChorusRiserDragMove);
    document.removeEventListener('mouseup', handleChorusRiserDragEnd);
    document.removeEventListener('touchmove', handleChorusRiserDragMove);
    document.removeEventListener('touchend', handleChorusRiserDragEnd);
}

function updateChorusRiserPosition(riserData) {
    const riserElement = document.getElementById(riserData.id);
    const labelElement = document.getElementById(riserData.id + '-label');
    
    if (riserElement) {
        riserElement.setAttribute('x', riserData.x);
        riserElement.setAttribute('y', riserData.y);
    }
    
    if (labelElement) {
        labelElement.setAttribute('x', riserData.x + riserData.config.width / 2);
        labelElement.setAttribute('y', riserData.y + riserData.config.height / 2 + 5);
    }
}

function moveChorusRiser(riserId, deltaX, deltaY) {
    const riserData = chorusRisers.find(r => r.id === riserId);
    if (!riserData) return;
    
    let newX = riserData.x + deltaX;
    let newY = riserData.y + deltaY;
    
    // Constrain to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000 - riserData.config.width,
        top: 0,
        bottom: 940 - riserData.config.height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Calculate actual movement delta
    const actualDeltaX = newX - riserData.x;
    const actualDeltaY = newY - riserData.y;
    
    // Don't use snap-to for keyboard movement (too aggressive for 1px movements)
    // Just update to the new position directly
    riserData.x = newX;
    riserData.y = newY;
    updateChorusRiserPosition(riserData);
    
    // Move singers on this riser
    moveSingersWithRiser(riserId, actualDeltaX, actualDeltaY);
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function moveSingersWithRiser(riserId, deltaX, deltaY) {
    // Extract row number from riser ID (e.g., "chorus-riser-1" -> riser #1, which is row 0, riser 0)
    const riserNumber = parseInt(riserId.match(/chorus-riser-(\d+)/)?.[1] || '0');
    if (riserNumber === 0) return;
    
    // Calculate which row this riser belongs to (4 risers per row)
    const rowIndex = Math.floor((riserNumber - 1) / 4);
    
    // Find all singers in this row and move them
    const singersInRow = chorusSingers.filter(s => s.rowIndex === rowIndex);
    
    singersInRow.forEach(singerData => {
        singerData.x += deltaX;
        singerData.y += deltaY;
        
        // Update the visual element
        const singerElement = document.getElementById(singerData.id);
        if (singerElement) {
            singerElement.setAttribute('x', singerData.x - singerData.size / 2);
            singerElement.setAttribute('y', singerData.y - singerData.size / 2);
        }
    });
}

function clearChorusRisers() {
    // Remove all chorus riser elements from DOM
    chorusRisers.forEach(riserData => {
        const riser = document.getElementById(riserData.id);
        const label = document.getElementById(riserData.id + '-label');
        if (riser) riser.remove();
        if (label) label.remove();
    });
    
    // Clear the array (but don't reset chorusRows - that's managed by caller)
    chorusRisers = [];
}

function addChorusRow() {
    if (!chorusEnabled) return;
    
    chorusRows++;
    chorusSingersPerRow.push(0); // Add entry for new row with 0 singers
    
    // Clear and recreate all risers with new row count
    clearChorusRisers();
    createChorusRisers();
    updateChorusRowInputs();
    updateChorusRowCount();
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function removeChorusRow() {
    if (!chorusEnabled || chorusRows <= 1) return;
    
    // Remove singers from the last row before removing the row
    const lastRowIndex = chorusRows - 1;
    clearChorusSingersForRow(lastRowIndex);
    
    chorusRows--;
    chorusSingersPerRow.pop(); // Remove the last row's singer count
    
    // Clear and recreate all risers with new row count
    clearChorusRisers();
    createChorusRisers();
    updateChorusRowInputs();
    updateChorusRowCount();
    updateTotalSingersCount();
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function updateChorusRowCount() {
    const countDisplay = document.getElementById('chorus-row-count');
    if (countDisplay) {
        countDisplay.textContent = `Rows: ${chorusRows}`;
    }
}

function updateChorusRowInputs() {
    const container = document.getElementById('chorus-row-inputs');
    if (!container) return;
    
    // Clear existing inputs
    container.innerHTML = '';
    
    // Ensure we have an array entry for each row
    while (chorusSingersPerRow.length < chorusRows) {
        chorusSingersPerRow.push(0);
    }
    
    // Trim if we have too many entries
    if (chorusSingersPerRow.length > chorusRows) {
        chorusSingersPerRow = chorusSingersPerRow.slice(0, chorusRows);
    }
    
    // Create input for each row
    for (let i = 0; i < chorusRows; i++) {
        const rowDiv = document.createElement('div');
        rowDiv.className = 'input-group';
        rowDiv.style.marginBottom = '8px';
        
        const label = document.createElement('label');
        label.textContent = `Row ${i + 1} Singers:`;
        label.style.minWidth = '110px';
        
        const input = document.createElement('input');
        input.type = 'number';
        input.id = `chorus-row-${i + 1}-singers`;
        input.min = '0';
        input.max = '19';
        input.value = chorusSingersPerRow[i] || 0;
        input.style.width = '60px';
        input.onchange = function() {
            updateChorusSingersForRow(i, parseInt(this.value) || 0);
        };
        
        rowDiv.appendChild(label);
        rowDiv.appendChild(input);
        container.appendChild(rowDiv);
    }
}

function updateChorusSingersForRow(rowIndex, singerCount) {
    // Update the count for this row
    chorusSingersPerRow[rowIndex] = singerCount;
    
    // Remove singers for this row
    clearChorusSingersForRow(rowIndex);
    
    // Create new singers for this row
    if (singerCount > 0) {
        createSingersForRow(rowIndex, singerCount);
    }
    
    // Update total count
    updateTotalSingersCount();
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function createSingersForRow(rowIndex, singerCount) {
    const section = document.getElementById('chorus-singers-section');
    if (!section) return;
    
    // Get the risers for this row by filtering based on riser number
    // Each row has risers numbered: row 0 = risers 1-4, row 1 = risers 5-8, etc.
    const firstRiserNumber = rowIndex * 4 + 1;
    const lastRiserNumber = firstRiserNumber + 3;
    
    const rowRisers = chorusRisers.filter(riser => {
        const riserNumber = parseInt(riser.id.match(/chorus-riser-(\d+)/)?.[1] || '0');
        return riserNumber >= firstRiserNumber && riserNumber <= lastRiserNumber;
    });
    
    if (rowRisers.length === 0) {
        console.error('No risers found for row', rowIndex);
        return;
    }
    
    // Sort risers by X position (left to right)
    rowRisers.sort((a, b) => a.x - b.x);
    
    // Calculate total width based on remaining risers
    // Width is from left edge of leftmost riser to right edge of rightmost riser
    const firstRiserLeft = rowRisers[0].x;
    const lastRiserRight = rowRisers[rowRisers.length - 1].x + rowRisers[rowRisers.length - 1].config.width;
    const totalWidth = lastRiserRight - firstRiserLeft;
    
    // Singer size: 1.7 feet = 25.5 pixels
    const singerSize = 1.7 * PIXELS_PER_FOOT; // 25.5px
    
    // Get Y position (center of risers in this row)
    const riserY = rowRisers[0].y;
    const riserHeight = rowRisers[0].config.height; // 60px (4 feet)
    const singerCenterY = riserY + riserHeight / 2;
    
    // Calculate spacing to spread singers evenly across the remaining width
    const spacing = (totalWidth - (singerCount * singerSize)) / (singerCount + 1);
    
    // Create singers
    for (let i = 0; i < singerCount; i++) {
        const singerX = firstRiserLeft + spacing + (i * (singerSize + spacing)) + singerSize / 2;
        const singerId = `singer-row${rowIndex + 1}-${i + 1}`;
        
        const singerData = {
            id: singerId,
            rowIndex: rowIndex,
            x: singerX,
            y: singerCenterY,
            size: singerSize
        };
        
        chorusSingers.push(singerData);
        createSingerElement(singerData);
    }
}

function createSingerElement(singerData) {
    const section = document.getElementById('chorus-singers-section');
    if (!section) return;
    
    // Create singer square (red, 1.7 feet = 25.5px)
    const singer = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    singer.setAttribute('id', singerData.id);
    singer.setAttribute('x', singerData.x - singerData.size / 2);
    singer.setAttribute('y', singerData.y - singerData.size / 2);
    singer.setAttribute('width', singerData.size);
    singer.setAttribute('height', singerData.size);
    singer.setAttribute('fill', '#dc2626'); // Red color
    singer.setAttribute('stroke', '#991b1b');
    singer.setAttribute('stroke-width', '1');
    singer.setAttribute('data-singer-id', singerData.id);
    singer.setAttribute('data-row-index', singerData.rowIndex);
    singer.classList.add('chorus-singer');
    singer.style.cursor = 'move';
    
    section.appendChild(singer);
    
    // Make singer draggable
    makeSingerDraggable(singer, singerData.id);
}

function makeSingerDraggable(singer, singerId) {
    singer.addEventListener('mousedown', function(e) {
        // Handle Ctrl/Cmd/Shift click for multi-select
        if (e.ctrlKey || e.metaKey || e.shiftKey) {
            togglePlayerSelection(singerId, singer);
            e.preventDefault();
            return;
        }
        
        // If this singer is not selected, clear selection and select only this singer
        if (!selectedPlayers.has(singerId)) {
            clearSelection();
            addToSelection(singerId, singer);
        }
        
        startSingerDrag(e, singer, singerId);
    });
    
    singer.addEventListener('click', function(e) {
        if (!isDragging) {
            e.stopPropagation();
            selectObject(singerId, 'singer');
        }
    });
}

function startSingerDrag(e, singer, singerId) {
    isDragging = true;
    draggedElement = singer;
    draggedLabel = null; // Singers don't have labels

    // Check if we're dragging multiple singers/players
    isGroupDragging = selectedPlayers.size > 1;
    
    // Add dragging class for visual feedback
    if (isGroupDragging) {
        selectedPlayers.forEach(id => {
            const p = document.querySelector(`[data-player-id="${id}"], [data-singer-id="${id}"]`);
            if (p) p.classList.add('dragging');
        });
    } else {
        singer.classList.add('dragging');
    }

    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    // Calculate scaling factors
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    // Calculate mouse position in SVG coordinates
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    // Calculate offset from center of singer
    const singerData = chorusSingers.find(s => s.id === singerId);
    if (!singerData) return;
    
    dragOffset = {
        x: mouseX - singerData.x,
        y: mouseY - singerData.y
    };

    // If group dragging, calculate offsets for all selected singers/players
    if (isGroupDragging) {
        groupDragOffsets.clear();
        groupDragLabels.clear();
        selectedPlayers.forEach(id => {
            const element = document.querySelector(`[data-player-id="${id}"], [data-singer-id="${id}"]`);
            if (element) {
                let elemX, elemY;
                
                // Check if it's a singer or player
                if (element.hasAttribute('data-singer-id')) {
                    const sData = chorusSingers.find(s => s.id === id);
                    if (sData) {
                        elemX = sData.x;
                        elemY = sData.y;
                    }
                } else {
                    elemX = parseFloat(element.getAttribute('cx'));
                    elemY = parseFloat(element.getAttribute('cy'));
                }
                
                if (elemX !== undefined && elemY !== undefined) {
                    groupDragOffsets.set(id, {
                        x: mouseX - elemX,
                        y: mouseY - elemY
                    });
                }
            }
        });
    }

    // Add global event listeners
    document.addEventListener('mousemove', handleSingerDragMove);
    document.addEventListener('mouseup', handleSingerDragEnd);
}

function handleSingerDragMove(e) {
    if (!isDragging || !draggedElement) return;

    e.preventDefault();
    
    // Get mouse position
    const clientX = e.clientX;
    const clientY = e.clientY;
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    if (isGroupDragging) {
        // Update all selected singers/players
        selectedPlayers.forEach(id => {
            const offset = groupDragOffsets.get(id);
            if (!offset) return;
            
            let newX = mouseX - offset.x;
            let newY = mouseY - offset.y;
            
            // Constrain to canvas
            newX = Math.max(0, Math.min(1000, newX));
            newY = Math.max(0, Math.min(940, newY));
            
            // Update element
            const element = document.querySelector(`[data-player-id="${id}"], [data-singer-id="${id}"]`);
            if (element) {
                if (element.hasAttribute('data-singer-id')) {
                    // It's a singer (rect)
                    const sData = chorusSingers.find(s => s.id === id);
                    if (sData) {
                        sData.x = newX;
                        sData.y = newY;
                        element.setAttribute('x', newX - sData.size / 2);
                        element.setAttribute('y', newY - sData.size / 2);
                    }
                } else {
                    // It's a player (circle/ellipse)
                    element.setAttribute('cx', newX);
                    element.setAttribute('cy', newY);
                    updatePlayerOrientation(element, newX, newY);
                }
            }
        });
    } else {
        // Single singer drag
        let newX = mouseX - dragOffset.x;
        let newY = mouseY - dragOffset.y;
        
        // Constrain to canvas
        newX = Math.max(0, Math.min(1000, newX));
        newY = Math.max(0, Math.min(940, newY));
        
        // Update singer position
        const singerId = draggedElement.getAttribute('data-singer-id');
        const singerData = chorusSingers.find(s => s.id === singerId);
        if (singerData) {
            singerData.x = newX;
            singerData.y = newY;
            draggedElement.setAttribute('x', newX - singerData.size / 2);
            draggedElement.setAttribute('y', newY - singerData.size / 2);
        }
    }
}

function handleSingerDragEnd(e) {
    if (isDragging && draggedElement) {
        // Remove dragging class
        if (isGroupDragging) {
            selectedPlayers.forEach(id => {
                const p = document.querySelector(`[data-player-id="${id}"], [data-singer-id="${id}"]`);
                if (p) p.classList.remove('dragging');
            });
        } else {
            draggedElement.classList.remove('dragging');
        }

        // Clean up
        isDragging = false;
        isGroupDragging = false;
        draggedElement = null;
        draggedLabel = null;
        dragOffset = { x: 0, y: 0 };
        groupDragOffsets.clear();
        groupDragLabels.clear();
    }

    // Remove global event listeners
    document.removeEventListener('mousemove', handleSingerDragMove);
    document.removeEventListener('mouseup', handleSingerDragEnd);
}

function clearChorusSingersForRow(rowIndex) {
    // Remove singers for this specific row
    const singersToRemove = chorusSingers.filter(s => s.rowIndex === rowIndex);
    singersToRemove.forEach(singerData => {
        const singerElement = document.getElementById(singerData.id);
        if (singerElement) singerElement.remove();
    });
    
    // Remove from array
    chorusSingers = chorusSingers.filter(s => s.rowIndex !== rowIndex);
}

function clearAllChorusSingers() {
    // Remove all singer elements from DOM
    chorusSingers.forEach(singerData => {
        const singerElement = document.getElementById(singerData.id);
        if (singerElement) singerElement.remove();
    });
    
    // Clear the array
    chorusSingers = [];
}

function updateTotalSingersCount() {
    const totalCount = chorusSingersPerRow.reduce((sum, count) => sum + count, 0);
    const countDisplay = document.getElementById('total-singers-count');
    if (countDisplay) {
        countDisplay.textContent = totalCount;
    }
}

// ===================================
// End Chorus Functions
// ===================================

function initializeConcertGrand() {
    const concertGrandRect = document.getElementById('concert-grand-rect');
    
    if (concertGrandRect) {
        concertGrandRect.addEventListener('mousedown', startConcertGrandDrag);
        concertGrandRect.addEventListener('touchstart', function(e) {
            e.preventDefault();
            startConcertGrandDrag(e.touches[0]);
        });
        
        // Add click event for keyboard selection
        concertGrandRect.addEventListener('click', function(e) {
            if (!concertGrandDragging) {
                e.stopPropagation();
                selectObject('concert-grand-rect', 'concert-grand');
            }
        });
    }
}

function startConcertGrandDrag(e) {
    concertGrandDragging = true;
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const clientX = e.clientX || e.pageX;
    const clientY = e.clientY || e.pageY;
    
    concertGrandDragOffset = {
        x: (clientX - rect.left) * scaleX - concertGrandPosition.x,
        y: (clientY - rect.top) * scaleY - concertGrandPosition.y
    };
    
    document.addEventListener('mousemove', handleConcertGrandDragMove);
    document.addEventListener('mouseup', handleConcertGrandDragEnd);
    document.addEventListener('touchmove', handleConcertGrandDragMove);
    document.addEventListener('touchend', handleConcertGrandDragEnd);
}

function handleConcertGrandDragMove(e) {
    if (!concertGrandDragging) return;
    
    e.preventDefault();
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX) || e.pageX;
    const clientY = e.clientY || (e.touches && e.touches[0].clientY) || e.pageY;
    
    let newX = (clientX - rect.left) * scaleX - concertGrandDragOffset.x;
    let newY = (clientY - rect.top) * scaleY - concertGrandDragOffset.y;
    
    // Update position without boundary constraints (like risers and podium)
    concertGrandPosition = { x: newX, y: newY };
    updateConcertGrandPosition();
}

function handleConcertGrandDragEnd(e) {
    if (concertGrandDragging) {
        concertGrandDragging = false;
        concertGrandDragOffset = { x: 0, y: 0 };
    }
    
    document.removeEventListener('mousemove', handleConcertGrandDragMove);
    document.removeEventListener('mouseup', handleConcertGrandDragEnd);
    document.removeEventListener('touchmove', handleConcertGrandDragMove);
    document.removeEventListener('touchend', handleConcertGrandDragEnd);
}

function updateConcertGrandPosition() {
    const concertGrandPath = document.getElementById('concert-grand-rect');
    const concertGrandLabel = document.getElementById('concert-grand-label');
    
    // The path is defined with its center at (500, 705)
    // We need to translate it to the desired position
    const pathCenterX = 500;
    const pathCenterY = 705;
    const translateX = concertGrandPosition.x - pathCenterX;
    const translateY = concertGrandPosition.y - pathCenterY;
    
    concertGrandPath.setAttribute('transform', `translate(${translateX}, ${translateY})`);
    
    // Update label position
    concertGrandLabel.setAttribute('x', concertGrandPosition.x);
    concertGrandLabel.setAttribute('y', concertGrandPosition.y);
}

function moveConcertGrand(deltaX, deltaY) {
    let newX = concertGrandPosition.x + deltaX;
    let newY = concertGrandPosition.y + deltaY;
    
    // Update position without boundary constraints (like risers and podium)
    concertGrandPosition = { x: newX, y: newY };
    updateConcertGrandPosition();
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

// Timpani Riser drag functionality
let timpaniRiserPosition = { x: 260, y: 95 }; // Default position in upstage corner
let timpaniRiserDragging = false;
let timpaniRiserDragOffset = { x: 0, y: 0 };

function initializeTimpaniRiser() {
    const timpaniRiser = document.getElementById('timpani-riser');
    
    if (timpaniRiser) {
        timpaniRiser.addEventListener('mousedown', startTimpaniRiserDrag);
        timpaniRiser.addEventListener('touchstart', function(e) {
            e.preventDefault();
            startTimpaniRiserDrag(e.touches[0]);
        });
        
        // Add click event for keyboard selection
        timpaniRiser.addEventListener('click', function(e) {
            if (!timpaniRiserDragging) {
                e.stopPropagation();
                selectObject('timpani-riser', 'timpani-riser');
            }
        });
    }
}

// Brass Risers drag functionality
let brassRiserPositions = {
    'brass-riser-1': { x: 380, y: 95 },
    'brass-riser-2': { x: 500, y: 95 },
    'brass-riser-3': { x: 620, y: 95 },
    'brass-riser-4': { x: 380, y: 155 },
    'brass-riser-5': { x: 500, y: 155 }
};
let brassRiserDragging = false;
let currentBrassRiser = null;
let brassRiserDragOffset = { x: 0, y: 0 };

// Woodwind Risers drag functionality
let woodwindRiserPositions = {
    'woodwind-riser-1': { x: 380, y: 245 },
    'woodwind-riser-2': { x: 500, y: 245 },
    'woodwind-riser-3': { x: 380, y: 305 },
    'woodwind-riser-4': { x: 500, y: 305 }
};
let woodwindRiserDragging = false;
let currentWoodwindRiser = null;
let woodwindRiserDragOffset = { x: 0, y: 0 };

function initializeBrassRisers() {
    const brassRiserIds = ['brass-riser-1', 'brass-riser-2', 'brass-riser-3', 'brass-riser-4', 'brass-riser-5'];
    
    brassRiserIds.forEach(id => {
        const riser = document.getElementById(id);
        if (riser) {
            riser.addEventListener('mousedown', function(e) {
                startBrassRiserDrag(e, id);
            });
            riser.addEventListener('touchstart', function(e) {
                e.preventDefault();
                startBrassRiserDrag(e.touches[0], id);
            });
            
            // Add click event for keyboard selection
            riser.addEventListener('click', function(e) {
                if (!brassRiserDragging) {
                    e.stopPropagation();
                    selectObject(id, 'brass-riser');
                }
            });
        }
    });
}

function initializeWoodwindRisers() {
    const woodwindRiserIds = ['woodwind-riser-1', 'woodwind-riser-2', 'woodwind-riser-3', 'woodwind-riser-4'];
    
    woodwindRiserIds.forEach(id => {
        const riser = document.getElementById(id);
        if (riser) {
            riser.addEventListener('mousedown', function(e) {
                startWoodwindRiserDrag(e, id);
            });
            riser.addEventListener('touchstart', function(e) {
                e.preventDefault();
                startWoodwindRiserDrag(e.touches[0], id);
            });
            
            // Add click event for keyboard selection
            riser.addEventListener('click', function(e) {
                if (!woodwindRiserDragging) {
                    e.stopPropagation();
                    selectObject(id, 'woodwind-riser');
                }
            });
        }
    });
}

function startBrassRiserDrag(e, riserId) {
    // Handle multi-selection with Ctrl/Cmd/Shift key
    if (e.ctrlKey || e.metaKey || e.shiftKey) {
        toggleRiserSelection(riserId);
        return; // Don't start dragging, just toggle selection
    }
    
    // If clicking on a non-selected riser, clear other selections
    if (!selectedRisers.has(riserId)) {
        clearRiserSelection();
        selectRiser(riserId);
    }
    
    // Check if we're starting a group drag
    if (selectedRisers.size > 1) {
        isGroupDraggingRisers = true;
    }
    
    brassRiserDragging = true;
    currentBrassRiser = riserId;
    
    // Add dragging class
    document.getElementById(riserId).classList.add('dragging');
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    brassRiserDragOffset = {
        x: mouseX - brassRiserPositions[riserId].x,
        y: mouseY - brassRiserPositions[riserId].y
    };

    // If group dragging, calculate offsets for all selected risers
    if (isGroupDraggingRisers) {
        groupRiserDragOffsets.clear();
        selectedRisers.forEach(id => {
            const riser = document.getElementById(id);
            if (riser && riser.getAttribute('data-riser-type')) {
                let riserX, riserY;
                if (id.startsWith('brass-riser-')) {
                    riserX = brassRiserPositions[id].x;
                    riserY = brassRiserPositions[id].y;
                } else if (id.startsWith('woodwind-riser-')) {
                    riserX = woodwindRiserPositions[id].x;
                    riserY = woodwindRiserPositions[id].y;
                } else if (id === 'timpani-riser') {
                    riserX = parseFloat(riser.getAttribute('x'));
                    riserY = parseFloat(riser.getAttribute('y'));
                }
                
                groupRiserDragOffsets.set(id, {
                    x: mouseX - riserX,
                    y: mouseY - riserY
                });
                riser.classList.add('dragging');
            }
        });
    }

    // Add global event listeners
    document.addEventListener('mousemove', handleBrassRiserDragMove);
    document.addEventListener('mouseup', handleBrassRiserDragEnd);
    document.addEventListener('touchmove', handleBrassRiserDragMove);
    document.addEventListener('touchend', handleBrassRiserDragEnd);
}

function handleBrassRiserDragMove(e) {
    if (!brassRiserDragging || !currentBrassRiser) return;

    e.preventDefault();
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    let newX = mouseX - brassRiserDragOffset.x;
    let newY = mouseY - brassRiserDragOffset.y;
    
    // Allow unrestricted movement anywhere on canvas
    // Constrain only to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000,  // SVG viewBox width
        top: 0,
        bottom: 940   // SVG viewBox height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Apply snap-to functionality only when not group dragging (to maintain relative positions)
    if (!isGroupDraggingRisers) {
        const riserWidth = 120; // brass riser width
        const riserHeight = 60; // brass riser height
        const snapPosition = getSnapPosition(currentBrassRiser, newX, newY, riserWidth, riserHeight);
        newX = snapPosition.x;
        newY = snapPosition.y;
    }
    
    // Update riser position
    brassRiserPositions[currentBrassRiser] = { x: newX, y: newY };
    updateBrassRiserPosition(currentBrassRiser);
    
    // If group dragging, update all selected risers
    if (isGroupDraggingRisers) {
        selectedRisers.forEach(id => {
            if (id !== currentBrassRiser) {
                const offset = groupRiserDragOffsets.get(id);
                if (offset) {
                    let riserNewX = mouseX - offset.x;
                    let riserNewY = mouseY - offset.y;
                    
                    // Constrain to canvas boundaries
                    riserNewX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, riserNewX));
                    riserNewY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, riserNewY));
                    
                    // Update position based on riser type
                    if (id.startsWith('brass-riser-')) {
                        brassRiserPositions[id] = { x: riserNewX, y: riserNewY };
                        updateBrassRiserPosition(id);
                    } else if (id.startsWith('woodwind-riser-')) {
                        woodwindRiserPositions[id] = { x: riserNewX, y: riserNewY };
                        updateWoodwindRiserPosition(id);
                    } else if (id === 'timpani-riser') {
                        const timpaniRiser = document.getElementById('timpani-riser');
                        timpaniRiser.setAttribute('x', riserNewX);
                        timpaniRiser.setAttribute('y', riserNewY);
                    } else if (id.startsWith('extra-riser-')) {
                        const riserData = extraRisers.find(r => r.id === id);
                        if (riserData) {
                            riserData.x = riserNewX;
                            riserData.y = riserNewY;
                            updateExtraRiserPosition(riserData);
                        }
                    }
                }
            }
        });
    }
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function handleBrassRiserDragEnd(e) {
    if (brassRiserDragging && currentBrassRiser) {
        // Remove dragging class from current riser
        document.getElementById(currentBrassRiser).classList.remove('dragging');
        
        // If group dragging, remove dragging class from all selected risers
        if (isGroupDraggingRisers) {
            selectedRisers.forEach(id => {
                const riser = document.getElementById(id);
                if (riser) {
                    riser.classList.remove('dragging');
                }
            });
            isGroupDraggingRisers = false;
            groupRiserDragOffsets.clear();
        }
        
        brassRiserDragging = false;
        currentBrassRiser = null;
        brassRiserDragOffset = { x: 0, y: 0 };
    }

    // Prevent focus and blur any focused element to avoid blue box
    e.preventDefault();
    if (document.activeElement) {
        document.activeElement.blur();
    }

    // Remove global event listeners
    document.removeEventListener('mousemove', handleBrassRiserDragMove);
    document.removeEventListener('mouseup', handleBrassRiserDragEnd);
    document.removeEventListener('touchmove', handleBrassRiserDragMove);
    document.removeEventListener('touchend', handleBrassRiserDragEnd);
}

function updateBrassRiserPosition(riserId) {
    const riser = document.getElementById(riserId);
    const riserLabel = document.getElementById(riserId + '-label');
    
    if (riser && riserLabel) {
        const pos = brassRiserPositions[riserId];
        riser.setAttribute('x', pos.x);
        riser.setAttribute('y', pos.y);
        
        // Center the label in the riser
        riserLabel.setAttribute('x', pos.x + 60); // Half of 120
        riserLabel.setAttribute('y', pos.y + 35); // Slightly below center
    }
}

function resetBrassRiserPositions() {
    // Reset to default positions
    brassRiserPositions = {
        'brass-riser-1': { x: 380, y: 95 },
        'brass-riser-2': { x: 500, y: 95 },
        'brass-riser-3': { x: 620, y: 95 },
        'brass-riser-4': { x: 380, y: 155 },
        'brass-riser-5': { x: 500, y: 155 }
    };
    
    Object.keys(brassRiserPositions).forEach(riserId => {
        updateBrassRiserPosition(riserId);
    });
}

function startWoodwindRiserDrag(e, riserId) {
    // Handle multi-selection with Ctrl/Cmd/Shift key
    if (e.ctrlKey || e.metaKey || e.shiftKey) {
        toggleRiserSelection(riserId);
        return; // Don't start dragging, just toggle selection
    }
    
    // If clicking on a non-selected riser, clear other selections
    if (!selectedRisers.has(riserId)) {
        clearRiserSelection();
        selectRiser(riserId);
    }
    
    // Check if we're starting a group drag
    if (selectedRisers.size > 1) {
        isGroupDraggingRisers = true;
    }
    
    woodwindRiserDragging = true;
    currentWoodwindRiser = riserId;
    
    // Add dragging class
    document.getElementById(riserId).classList.add('dragging');
    
    // Get SVG coordinate system
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (e.clientX - rect.left) * scaleX;
    const mouseY = (e.clientY - rect.top) * scaleY;
    
    woodwindRiserDragOffset = {
        x: mouseX - woodwindRiserPositions[riserId].x,
        y: mouseY - woodwindRiserPositions[riserId].y
    };

    // If group dragging, calculate offsets for all selected risers
    if (isGroupDraggingRisers) {
        groupRiserDragOffsets.clear();
        selectedRisers.forEach(id => {
            const riser = document.getElementById(id);
            if (riser && riser.getAttribute('data-riser-type')) {
                let riserX, riserY;
                if (id.startsWith('brass-riser-')) {
                    riserX = brassRiserPositions[id].x;
                    riserY = brassRiserPositions[id].y;
                } else if (id.startsWith('woodwind-riser-')) {
                    riserX = woodwindRiserPositions[id].x;
                    riserY = woodwindRiserPositions[id].y;
                } else if (id === 'timpani-riser') {
                    riserX = parseFloat(riser.getAttribute('x'));
                    riserY = parseFloat(riser.getAttribute('y'));
                }
                
                groupRiserDragOffsets.set(id, {
                    x: mouseX - riserX,
                    y: mouseY - riserY
                });
                riser.classList.add('dragging');
            }
        });
    }

    // Add global event listeners
    document.addEventListener('mousemove', handleWoodwindRiserDragMove);
    document.addEventListener('mouseup', handleWoodwindRiserDragEnd);
    document.addEventListener('touchmove', handleWoodwindRiserDragMove);
    document.addEventListener('touchend', handleWoodwindRiserDragEnd);
}

function handleWoodwindRiserDragMove(e) {
    if (!woodwindRiserDragging || !currentWoodwindRiser) return;

    e.preventDefault();
    
    const clientX = e.clientX || (e.touches && e.touches[0].clientX);
    const clientY = e.clientY || (e.touches && e.touches[0].clientY);
    
    const svg = document.querySelector('.stage-plot');
    const rect = svg.getBoundingClientRect();
    const svgRect = svg.viewBox.baseVal;
    
    const scaleX = svgRect.width / rect.width;
    const scaleY = svgRect.height / rect.height;
    
    const mouseX = (clientX - rect.left) * scaleX;
    const mouseY = (clientY - rect.top) * scaleY;
    
    let newX = mouseX - woodwindRiserDragOffset.x;
    let newY = mouseY - woodwindRiserDragOffset.y;
    
    // Allow unrestricted movement anywhere on canvas
    // Constrain only to canvas boundaries
    const canvasBounds = {
        left: 0,
        right: 1000,  // SVG viewBox width
        top: 0,
        bottom: 940   // SVG viewBox height
    };
    
    newX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, newX));
    newY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, newY));
    
    // Apply snap-to functionality only when not group dragging (to maintain relative positions)
    if (!isGroupDraggingRisers) {
        const riserWidth = 120; // woodwind riser width
        const riserHeight = 60; // woodwind riser height
        const snapPosition = getSnapPosition(currentWoodwindRiser, newX, newY, riserWidth, riserHeight);
        newX = snapPosition.x;
        newY = snapPosition.y;
    }
    
    // Update riser position
    woodwindRiserPositions[currentWoodwindRiser] = { x: newX, y: newY };
    updateWoodwindRiserPosition(currentWoodwindRiser);
    
    // If group dragging, update all selected risers
    if (isGroupDraggingRisers) {
        selectedRisers.forEach(id => {
            if (id !== currentWoodwindRiser) {
                const offset = groupRiserDragOffsets.get(id);
                if (offset) {
                    let riserNewX = mouseX - offset.x;
                    let riserNewY = mouseY - offset.y;
                    
                    // Constrain to canvas boundaries
                    riserNewX = Math.max(canvasBounds.left, Math.min(canvasBounds.right, riserNewX));
                    riserNewY = Math.max(canvasBounds.top, Math.min(canvasBounds.bottom, riserNewY));
                    
                    // Update position based on riser type
                    if (id.startsWith('brass-riser-')) {
                        brassRiserPositions[id] = { x: riserNewX, y: riserNewY };
                        updateBrassRiserPosition(id);
                    } else if (id.startsWith('woodwind-riser-')) {
                        woodwindRiserPositions[id] = { x: riserNewX, y: riserNewY };
                        updateWoodwindRiserPosition(id);
                    } else if (id === 'timpani-riser') {
                        const timpaniRiser = document.getElementById('timpani-riser');
                        timpaniRiser.setAttribute('x', riserNewX);
                        timpaniRiser.setAttribute('y', riserNewY);
                        timpaniRiserPosition.x = riserNewX;
                        timpaniRiserPosition.y = riserNewY;
                    } else if (id.startsWith('extra-riser-')) {
                        const riserData = extraRisers.find(r => r.id === id);
                        if (riserData) {
                            riserData.x = riserNewX;
                            riserData.y = riserNewY;
                            updateExtraRiserPosition(riserData);
                        }
                    }
                }
            }
        });
    }
    
    // Update debug info if in debug mode
    if (debugMode) {
        updateDebugInfo();
    }
}

function handleWoodwindRiserDragEnd(e) {
    if (woodwindRiserDragging && currentWoodwindRiser) {
        // Remove dragging class from current riser
        document.getElementById(currentWoodwindRiser).classList.remove('dragging');
        
        // If group dragging, remove dragging class from all selected risers
